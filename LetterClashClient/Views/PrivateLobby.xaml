<Page x:Class="LetterClashClient.Views.PrivateLobby"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="PrivateLobby"
      Loaded="Page_Loaded">

    <Grid Background="#F4F4F4">
        <Border Margin="20"
            BorderBrush="#2B2B2B"
            BorderThickness="2"
            Background="White">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
              Margin="30,25,30,20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="105"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50*"/>
                            <ColumnDefinition Width="50*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                    Width="390"
                    Height="85"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image x:Name="ImageUserAvatar"
                       Grid.Column="0"
                       Source="/Assets/Images/UserAvatar.png"
                       Width="58"
                       Height="58"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">

                                    <TextBlock x:Name="TextBlockUsername"
                             Text="&quot;NOMBRE DE USUARIO&quot;"
                             FontSize="16"
                             FontWeight="SemiBold"
                             Foreground="#111111"
                             Margin="0,0,0,8"/>

                                    <TextBlock x:Name="TextBlockAge"
                             Text="&quot;EDAD&quot;"
                             FontSize="15"
                             FontWeight="SemiBold"
                             Foreground="#111111"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Image x:Name="ImageLogo"
                   Grid.Column="1"
                   Source="/Assets/Images/LogoLetterClash.jpeg"
                   Width="330"
                   Height="95"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
                    </Grid>

                    <Border Grid.Row="1"
                  Width="650"
                  Height="360"
                  BorderBrush="#2B2B2B"
                  BorderThickness="1"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top"
                  Margin="0,25,0,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="45"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                      BorderBrush="#2B2B2B"
                      BorderThickness="0,0,0,1">

                                <TextBlock Text="Entrar en Lobby Privado"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                            </Border>

                            <Grid Grid.Row="1"
                    Margin="45,35,45,35">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="80"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                           Text="Ingresa el Codigo de Acceso al Lobby"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="#111111"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                                <Grid Grid.Row="1"
                      Width="350"
                      Height="35"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">

                                    <TextBox x:Name="TextBoxAccessCode"
                           Height="35"
                           FontSize="15"
                           Padding="8,4"
                           TextChanged="TextBoxAccessCode_TextChanged"/>

                                    <TextBlock x:Name="TextBlockAccessCodePlaceholder"
                             Text="Código de acceso"
                             FontSize="15"
                             Foreground="#999999"
                             Margin="10,0,0,0"
                             VerticalAlignment="Center"
                             IsHitTestVisible="False"/>
                                </Grid>

                                <TextBlock x:Name="TextBlockAccessCodeError"
                           Grid.Row="2"
                           Text="Ingrese un código válido"
                           FontSize="14"
                           Foreground="Red"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Hidden"/>

                                <Button x:Name="ButtonSearchLobby"
                        Grid.Row="3"
                        Content="Buscar Lobby     ⌕"
                        Width="280"
                        Height="45"
                        FontSize="16"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Click="ButtonSearchLobby_Click"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                BorderBrush="#2B2B2B"
                BorderThickness="0,2,0,0"
                Background="#F7F7F7">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ButtonMainMenu"
                    Grid.Column="0"
                    Content="Menu Principal  ⚔"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonMainMenu_Click"/>

                        <Button x:Name="ButtonProfile"
                    Grid.Column="1"
                    Content="Perfil  👤"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonProfile_Click"/>

                        <Button x:Name="ButtonHistory"
                    Grid.Column="2"
                    Content="Historial  ◴"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonHistory_Click"/>

                        <Button x:Name="ButtonScoreboard"
                    Grid.Column="3"
                    Content="Marcadores  🏆"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonScoreboard_Click"/>

                        <Button x:Name="ButtonSettings"
                    Grid.Column="4"
                    Content="Ajustes  ⚙"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonSettings_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>