<Page x:Class="LetterClashClient.Views.GUIGameView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUIGameView"
      Loaded="Page_Loaded">

  <Page.Resources>
    <!-- Style for Bottom Navigation Bar Buttons -->
    <Style x:Key="NavBarButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#FF2D66"/>
      <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="Transparent"
                                BorderThickness="0" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="true">
                <Setter Property="Foreground" Value="#FF2D66"/>
                <Setter TargetName="border" Property="Background" Value="#FF2D6622"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="true">
                <Setter TargetName="border" Property="Background" Value="#FF2D6644"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Retro Cyberpunk Primary Button Style -->
    <Style x:Key="ModernPrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="#00FFCC"/>
      <Setter Property="Foreground" Value="#050D14"/>
      <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="true">
                <Setter TargetName="border" Property="Background" Value="#FFFFFF"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#FFFFFF"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="true">
                <Setter TargetName="border" Property="Background" Value="#99FFE8"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="false">
                <Setter TargetName="border" Property="Background" Value="#061A22"/>
                <Setter Property="Foreground" Value="#1A3D35"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Retro Cyberpunk Secondary Button Style -->
    <Style x:Key="ModernSecondaryButton" TargetType="Button">
      <Setter Property="Background" Value="#061A22"/>
      <Setter Property="Foreground" Value="#FF2D66"/>
      <Setter Property="BorderBrush" Value="#FF2D6688"/>
      <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
      <Setter Property="BorderThickness" Value="1.5"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="true">
                <Setter TargetName="border" Property="Background" Value="#FF2D6622"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#FF2D66"/>
                <Setter Property="Foreground" Value="#FF2D66"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="true">
                <Setter TargetName="border" Property="Background" Value="#FF2D6644"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="false">
                <Setter TargetName="border" Property="BorderBrush" Value="#0A1F2A"/>
                <Setter Property="Foreground" Value="#1A3D35"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Flat ProgressBar style -->
    <Style x:Key="FlatProgressBar" TargetType="ProgressBar">
      <Setter Property="Background" Value="#061A22"/>
      <Setter Property="BorderBrush" Value="#00FFCC33"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="#FF2D66"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ProgressBar">
            <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="0">
              <Grid x:Name="TemplateRoot">
                <Rectangle x:Name="PART_Track" />
                <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                  <Grid x:Name="IndicatorGrid">
                    <Rectangle x:Name="Indicator" Fill="{TemplateBinding Foreground}" />
                  </Grid>
                </Decorator>
              </Grid>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Page.Resources>

  <Grid>
    <!-- Cyberpunk Grid Line Background -->
    <Grid.Background>
      <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
          <GeometryDrawing>
            <GeometryDrawing.Geometry>
              <GeometryGroup>
                <LineGeometry StartPoint="0,0" EndPoint="40,0" />
                <LineGeometry StartPoint="0,0" EndPoint="0,40" />
              </GeometryGroup>
            </GeometryDrawing.Geometry>
            <GeometryDrawing.Pen>
              <Pen Brush="#0A1F2A" Thickness="1" />
            </GeometryDrawing.Pen>
          </GeometryDrawing>
        </DrawingBrush.Drawing>
      </DrawingBrush>
    </Grid.Background>

    <Border Margin="20"
                BorderBrush="#00FFCC33"
                BorderThickness="2"
                Background="#07131CCC"
                CornerRadius="0">

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="95"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Grid -->
        <Grid Grid.Row="0" Margin="30,10,30,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0"
                            Width="200"
                            Height="50"
                            BorderBrush="#00A986"
                            BorderThickness="1.5"
                            Background="#061A22"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            CornerRadius="0">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="55"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                                       Text="⚔"
                                       FontSize="24"
                                       Foreground="#00FFCC"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1"
                                       Text="{DynamicResource Game_Header}"
                                       FontSize="16"
                                       FontFamily="{StaticResource GeistPixelSquare}"
                                       Foreground="#00FFCC"
                                       VerticalAlignment="Center"/>
            </Grid>
          </Border>

          <Border Grid.Column="1"
                            Width="300"
                            Height="50"
                            BorderBrush="#00A986"
                            BorderThickness="1.5"
                            Background="#061A22"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            CornerRadius="0">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="55"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="65"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                                       Text="Vs"
                                       FontSize="15"
                                       FontFamily="{StaticResource GeistPixelSquare}"
                                       Foreground="#00A986"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
              <TextBlock x:Name="TextBlockOpponent"
                                       Grid.Column="1"
                                       Text="Usuario 1"
                                       FontSize="14"
                                       FontFamily="{StaticResource GeistMono}"
                                       Foreground="#00A986"
                                       VerticalAlignment="Center"/>
              <Image x:Name="ImageOpponentAvatar"
                                   Grid.Column="2"
                                   Source="/Assets/Images/UserAvatar.png"
                                   Width="38"
                                   Height="38"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
            </Grid>
          </Border>

          <Button x:Name="ButtonAbandon"
                            Grid.Column="2"
                            Content="{DynamicResource Game_BtnAbandon}"
                            Width="140"
                            Height="38"
                            BorderBrush="#00A986"
                            Style="{StaticResource ModernSecondaryButton}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Click="ButtonAbandon_Click"/>

          <Image x:Name="ImageLogo"
                           Grid.Column="3"
                           Source="/Assets/Images/LogoLetterClashRectangle.png"
                           Width="240"
                           Height="65"
                           Stretch="Uniform"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
        </Grid>

        <!-- Main Content Grid -->
        <Grid Grid.Row="1" Margin="0,5,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60*"/>
            <ColumnDefinition Width="40*"/>
          </Grid.ColumnDefinitions>

          <!-- Left Panel (Dynamically Toggled by Role) -->
          <Grid Grid.Column="0" x:Name="GridLeftContainer">

            <!-- Guesser View Panel -->            <Grid x:Name="GridGuesserSection" Visibility="Visible">
              <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="95"/>
                <RowDefinition Height="180"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <!-- Guesser Info Row (Code, Clue & Language) -->
              <Grid Grid.Row="0" Margin="0,15,0,0">
                  <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  
                  <!-- Access Code for Guesser -->
                  <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="25,0,0,0">
                      <TextBlock Text="{DynamicResource Game_AccessCodeLabel}"
                                 FontSize="11"
                                 FontFamily="{StaticResource GeistPixelSquare}"
                                 Foreground="#00A896"
                                 FontWeight="Bold"/>
                      <TextBlock x:Name="TextBlockAccessCodeGuesser"
                                 Text="------"
                                 FontSize="18"
                                 FontFamily="{StaticResource GeistMono}"
                                 FontWeight="Bold"
                                 Foreground="#00FFCC"
                                 Margin="0,4,0,0"/>
                  </StackPanel>
                  
                  <!-- Word Description Clue -->
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="340">
                      <TextBlock Text="PISTA / DESCRIPCIÓN"
                                 FontSize="11"
                                 FontFamily="{StaticResource GeistPixelSquare}"
                                 Foreground="#FF2D66"
                                 FontWeight="Bold"
                                 HorizontalAlignment="Center"
                                 Margin="0,0,0,4"/>
                      <TextBlock x:Name="TextBlockWordDescription"
                                 Text="Cargando pista de la palabra..."
                                 FontSize="13"
                                 FontFamily="{StaticResource GeistMono}"
                                 Foreground="#E0F7F4"
                                 HorizontalAlignment="Center"
                                 TextAlignment="Center"
                                 TextWrapping="Wrap"/>
                  </StackPanel>
                  
                  <!-- Room Language -->
                  <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,25,0">
                      <TextBlock Text="IDIOMA"
                                 FontSize="11"
                                 FontFamily="{StaticResource GeistPixelSquare}"
                                 Foreground="#00A896"
                                 FontWeight="Bold"
                                 HorizontalAlignment="Right"/>
                      <TextBlock x:Name="TextBlockLanguageGuesser"
                                 Text="ESPAÑOL"
                                 FontSize="14"
                                 FontFamily="{StaticResource GeistMono}"
                                 FontWeight="Bold"
                                 Foreground="#00FFCC"
                                 HorizontalAlignment="Right"
                                 Margin="0,4,0,0"/>
                  </StackPanel>
              </Grid>

              <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                  <TextBlock Text="PALABRA A ADIVINAR"
                             FontSize="11"
                             FontFamily="{StaticResource GeistPixelSquare}"
                             Foreground="#00A896"
                             FontWeight="Bold"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,8"/>
                  <TextBlock x:Name="TextBlockHiddenWord"
                             Text="_ _ _ _ _ _ _ _"
                             FontSize="38"
                             FontFamily="{StaticResource GeistMono}"
                             FontWeight="Bold"
                             Foreground="#4DEEEA"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
              </StackPanel>

              <Grid Grid.Row="2"
                                  Width="560"
                                  Height="155"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  x:Name="GridKeyboard">
                <Grid.Resources>
                  <!-- Keyboard cyberpunk keys style -->
                  <Style TargetType="Button">
                    <Setter Property="Background" Value="#061A22"/>
                    <Setter Property="Foreground" Value="#00FFCC"/>
                    <Setter Property="BorderBrush" Value="#00FFCC44"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
                    <Setter Property="FontSize" Value="15"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Margin" Value="2"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                      <Setter.Value>
                        <ControlTemplate TargetType="Button">
                          <Border x:Name="border" 
                                                            Background="{TemplateBinding Background}" 
                                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                                            BorderThickness="{TemplateBinding BorderThickness}" 
                                                            CornerRadius="0" 
                                                            SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                          </Border>
                          <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                              <Setter TargetName="border" Property="Background" Value="#00FFCC"/>
                              <Setter TargetName="border" Property="BorderBrush" Value="#00FFCC"/>
                              <Setter Property="Foreground" Value="#050D14"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                              <Setter TargetName="border" Property="Background" Value="#99FFE8"/>
                              <Setter Property="Foreground" Value="#050D14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                              <Setter TargetName="border" Property="Background" Value="#050D14"/>
                              <Setter TargetName="border" Property="BorderBrush" Value="#0A1F2A"/>
                              <Setter Property="Foreground" Value="#1A3D35"/>
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Setter.Value>
                    </Setter>
                  </Style>
                </Grid.Resources>
                <Grid.RowDefinitions>
                  <RowDefinition Height="50"/>
                  <RowDefinition Height="50"/>
                  <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0" Columns="10">
                  <Button Content="Q" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="W" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="E" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="R" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="T" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="Y" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="U" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="I" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="O" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="P" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                </UniformGrid>

                <UniformGrid Grid.Row="1" Columns="9" Margin="24,0,24,0">
                  <Button Content="A" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="S" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="D" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="F" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="G" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="H" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="J" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="K" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="L" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                </UniformGrid>

                <UniformGrid Grid.Row="2" Columns="7" Margin="70,0,70,0">
                  <Button Content="Z" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="X" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="C" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="V" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="B" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="N" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                  <Button Content="M" Click="ButtonLetter_Click" BorderBrush="#00A986"/>
                </UniformGrid>
              </Grid>
            </Grid>            <!-- Host View Panel -->
            <Grid x:Name="GridHostSection" Visibility="Collapsed">
              <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="45"/>
                <RowDefinition Height="85"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <!-- Host Info Row (Code, Clue & Language) -->
              <Grid Grid.Row="0" Margin="0,15,0,0">
                  <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  
                  <!-- Access Code for Host -->
                  <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="25,0,0,0">
                      <TextBlock Text="{DynamicResource Game_AccessCodeLabel}"
                                 FontSize="11"
                                 FontFamily="{StaticResource GeistPixelSquare}"
                                 Foreground="#00A896"
                                 FontWeight="Bold"/>
                      <TextBlock x:Name="TextBlockAccessCode"
                                 Text="------"
                                 FontSize="18"
                                 FontFamily="{StaticResource GeistMono}"
                                 FontWeight="Bold"
                                 Foreground="#00FFCC"
                                 Margin="0,4,0,0"/>
                  </StackPanel>
                  
                  <!-- Word Description Clue -->
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="340">
                      <TextBlock Text="PISTA / DESCRIPCIÓN"
                                 FontSize="11"
                                 FontFamily="{StaticResource GeistPixelSquare}"
                                 Foreground="#FF2D66"
                                 FontWeight="Bold"
                                 HorizontalAlignment="Center"
                                 Margin="0,0,0,4"/>
                      <TextBlock x:Name="TextBlockWordDescriptionHost"
                                 Text="Descripción de la palabra..."
                                 FontSize="13"
                                 FontFamily="{StaticResource GeistMono}"
                                 Foreground="#E0F7F4"
                                 HorizontalAlignment="Center"
                                 TextAlignment="Center"
                                 TextWrapping="Wrap"/>
                  </StackPanel>
                  
                  <!-- Room Language -->
                  <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,25,0">
                      <TextBlock Text="IDIOMA"
                                 FontSize="11"
                                 FontFamily="{StaticResource GeistPixelSquare}"
                                 Foreground="#00A896"
                                 FontWeight="Bold"
                                 HorizontalAlignment="Right"/>
                      <TextBlock x:Name="TextBlockLanguageHost"
                                 Text="ESPAÑOL"
                                 FontSize="14"
                                 FontFamily="{StaticResource GeistMono}"
                                 FontWeight="Bold"
                                 Foreground="#00FFCC"
                                 HorizontalAlignment="Right"
                                 Margin="0,4,0,0"/>
                  </StackPanel>
              </Grid>

              <TextBlock Grid.Row="1"
                                       Text="{DynamicResource Game_WordLabel}"
                                       FontSize="11"
                                       FontFamily="{StaticResource GeistPixelSquare}"
                                       Foreground="#00A896"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

              <TextBlock x:Name="TextBlockWord"
                                       Grid.Row="2"
                                       Text="SOFTWARE"
                                       FontSize="36"
                                       FontFamily="{StaticResource GeistMono}"
                                       FontWeight="Bold"
                                       Foreground="#E0F7F4"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

              <Border Grid.Row="3"
                                    Width="520"
                                    Height="120"
                                    BorderBrush="#00FFCC44"
                                    BorderThickness="1.5"
                                    Background="#061A22"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    CornerRadius="0">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>

                  <TextBlock Grid.Row="0"
                                               Text="{DynamicResource Game_ProposedLetterLabel}"
                                               FontSize="11"
                                               FontFamily="{StaticResource GeistPixelSquare}"
                                               Foreground="#00A896"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                  <TextBlock x:Name="TextBlockSelectedLetter"
                                               Grid.Row="1"
                                               Text="A"
                                               FontSize="36"
                                               FontFamily="{StaticResource GeistMono}"
                                               FontWeight="Bold"
                                               Foreground="#FF2D66"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                </Grid>
              </Border>
            </Grid>
          </Grid>

          <!-- Right Panel (Hangedman + Attempts + Chat) -->
          <Grid Grid.Column="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="220"/>
              <RowDefinition Height="40"/>
              <RowDefinition Height="190"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Canvas x:Name="CanvasHangmanGame"
                                Grid.Row="0"
                                Width="280"
                                Height="210"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
              <Image x:Name="ImageHangman"
                                   Source="/Assets/Images/Hangedman6.png"
                                   Width="220"
                                   Height="190"
                                   Stretch="Uniform"
                                   Canvas.Left="25"
                                   Canvas.Top="10"/>

              <Border x:Name="BorderUserAvatar"
                                    Width="58"
                                    Height="58"
                                    CornerRadius="0"
                                    BorderBrush="#00FFCC44"
                                    BorderThickness="2"
                                    Background="#061A22"
                                    Canvas.Left="173"
                                    Canvas.Top="47">
                <Image x:Name="ImageUserAvatar"
                                       Source="/Assets/Images/UserAvatar.png"
                                       Width="46"
                                       Height="46"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
              </Border>
            </Canvas>

            <Grid Grid.Row="1"
                              Width="300"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="55"/>
              </Grid.ColumnDefinitions>
              <ProgressBar x:Name="ProgressBarAttempts"
                                         Grid.Column="0"
                                         Height="20"
                                         Style="{StaticResource FlatProgressBar}"
                                         Minimum="0"
                                         Maximum="5"
                                         Value="0"/>
              <TextBlock x:Name="TextBlockAttempts"
                                       Grid.Column="1"
                                       Text="0/5"
                                       FontSize="15"
                                       FontFamily="{StaticResource GeistMono}"
                                       Foreground="#FF2D66"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
            </Grid>

            <Grid x:Name="GridChat"
                              Grid.Row="2"
                              Width="360"
                              Height="180"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Top">
              <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
              </Grid.RowDefinitions>

              <Border Grid.Row="0" 
                                    BorderBrush="#00A986"
                                    BorderThickness="1.5"
                                    Background="#04111A"
                                    CornerRadius="0">
                <TextBlock x:Name="TextBlockChatTitle"
                                           Text="{DynamicResource Game_ChatTitle}"
                                           FontSize="12"
                                           FontFamily="{StaticResource GeistPixelSquare}"
                                           Foreground="#4DEEEA"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
              </Border>

              <TextBox x:Name="TextBoxChatMessages"
                                     Grid.Row="1"
                                     FontSize="13"
                                     FontFamily="{StaticResource GeistMono}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#061A22"
                                     Foreground="#4DEEEA"
                                     BorderBrush="#00A986"
                                     BorderThickness="1.5,0,1.5,1.5"
                                     Padding="8"/>

              <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TextBoxChatInput"
                                         Grid.Column="0"
                                         FontSize="13"
                                         FontFamily="{StaticResource GeistMono}"
                                         Background="#061A22"
                                         Foreground="#4DEEEA"
                                         BorderBrush="#00A986"
                                         BorderThickness="1.5,0,1.5,1.5"
                                         CaretBrush="#00FFCC"
                                         Padding="8,6"
                                         VerticalContentAlignment="Center"/>
                <Button x:Name="ButtonSendMessage"
                                        Grid.Column="1"
                                        Content="{DynamicResource Game_BtnSend}"
                                        Style="{StaticResource ModernPrimaryButton}"
                                        FontSize="12"
                                        Height="36"
                                        Cursor="Hand"
                                        Click="ButtonSendMessage_Click"/>
              </Grid>
            </Grid>
          </Grid>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Page>

