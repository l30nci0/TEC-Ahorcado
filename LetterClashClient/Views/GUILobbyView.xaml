<Page x:Class="LetterClashClient.Views.GUILobbyView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUILobbyView"
      Loaded="Page_Loaded"
      Background="#0B0E14">

    <Page.Resources>
        <!-- Retro Grayscale Primary Button Style -->
        <Style x:Key="ModernPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#4DEEEA" Opacity="0.6"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00A896"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                 <Setter TargetName="border" Property="Background" Value="#27272A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#71717A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Retro Grayscale Secondary Button Style -->
        <Style x:Key="ModernSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#F649A7"/>
            <Setter Property="BorderBrush" Value="#E60067"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#9B004F" Opacity="0.6"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#F649A7"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F649A7"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#E60067"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E60067"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#181E29"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#52525B"/>
                                <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="0" ShadowDepth="0" Color="#000000" Opacity="0"/>
                                </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Bottom Navigation Bar Buttons -->
        <Style x:Key="NavBarButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1.5" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Foreground" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Foreground" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00A896"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Modern Dark TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="BorderBrush" Value="#00A896"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="CaretBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="neonGlow" BlurRadius="12" ShadowDepth="0" Color="#4DEEEA" Opacity="0.6"/>
                                </Border.Effect>
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter Property="Foreground" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00A896"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#181E29"/>
                                <Setter TargetName="border" Property="Background" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#181E29"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form Elements Generic Styles -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00A896"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>

        <Style x:Key="PlaceholderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#00A896"/>
            <Setter Property="Margin" Value="14,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <Style x:Key="ErrorLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#E60067"/>
            <Setter Property="Margin" Value="2,2,0,12"/>
            <Setter Property="Visibility" Value="Hidden"/>
        </Style>

        <!-- DataGrid Dark Grayscale Styles -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="BorderBrush" Value="#00A896"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#181E29"/>
            <Setter Property="VerticalGridLinesBrush" Value="#181E29"/>
            <Setter Property="RowBackground" Value="#0B0E14"/>
            <Setter Property="AlternatingRowBackground" Value="#181E29"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#181E29"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#00A896"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4DEEEA"/>
                    <Setter Property="Foreground" Value="#0B0E14"/>
                    <Setter Property="BorderBrush" Value="#4DEEEA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderBrush" Value="#00A896"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Modern Grid Line Background -->
        <Grid.Background>
            <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                <DrawingBrush.Drawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#15151A" Thickness="1"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,0" EndPoint="40,0"/>
                                <LineGeometry StartPoint="0,0" EndPoint="0,40"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </Grid.Background>

        <!-- Main Shell Grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Content Area -->
            <Grid Grid.Row="0" Margin="30,30,30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Section Title Header -->
                <TextBlock Grid.Row="0"
                           Text="{DynamicResource Lobby_Title}"
                           FontFamily="{StaticResource GeistPixelSquare}"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#4DEEEA"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="3" Color="#4DEEEA" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Tab Selectors Stack -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                    <Button x:Name="ButtonTabPublic"
                            Content="{DynamicResource Lobby_TabPublic}"
                            Width="200"
                            Height="40"
                            Style="{StaticResource ModernSecondaryButton}"
                            Margin="0,0,10,0"
                            Click="ButtonTabPublic_Click"/>

                    <Button x:Name="ButtonTabPrivate"
                            Content="{DynamicResource Lobby_TabPrivate}"
                            Width="200"
                            Height="40"
                            Style="{StaticResource ModernSecondaryButton}"
                            Click="ButtonTabPrivate_Click"/>
                </StackPanel>

                <!-- Consolidated Content Lobbies Grid -->
                <Grid Grid.Row="2">
                    
                    <!-- Public Lobby Card -->
                    <Border x:Name="BorderPublicLobby"
                            Width="950"
                            Height="400"
                            BorderBrush="#4DEEEA"
                            BorderThickness="1.5"
                            Background="#0B0E14"
                            CornerRadius="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Visibility="Visible"
                            Padding="0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#4DEEEA" Opacity="0.7"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Lobby Card Header -->
                            <Border Grid.Row="0"
                                    BorderBrush="#00A896"
                                    BorderThickness="0,0,0,1.5"
                                    Background="#0B0E14"
                                    Padding="15,0">
                                <Grid>
                                    <TextBlock Text="{DynamicResource Lobby_PublicTitle}"
                                               FontFamily="{StaticResource GeistPixelSquare}"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="#4DEEEA"
                                               VerticalAlignment="Center"/>
                                    
                                    <Button x:Name="ButtonRefreshLobby"
                                            Content="{DynamicResource Lobby_BtnRefresh}"
                                            Width="130"
                                            Height="30"
                                            Style="{StaticResource ModernPrimaryButton}"
                                            FontSize="11"
                                            HorizontalAlignment="Right"
                                            Click="ButtonRefreshLobby_Click"/>
                                </Grid>
                            </Border>

                            <!-- Data Grid -->
                            <DataGrid x:Name="DataGridPublicMatches"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="False"
                                      CanUserSortColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      Margin="10"
                                      Background="#0B0E14">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource Lobby_ColHost}"
                                                        Binding="{Binding NombreAnfitrion}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="{DynamicResource Lobby_ColLanguage}"
                                                        Binding="{Binding Idioma}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="{DynamicResource Lobby_ColPrivacy}"
                                                        Binding="{Binding Privacidad}"
                                                        Width="*"/>
                                    <DataGridTemplateColumn Header="{DynamicResource Lobby_ColAction}"
                                                            Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="{DynamicResource Lobby_BtnJoin}"
                                                        Width="110"
                                                        Height="26"
                                                        Style="{StaticResource ModernPrimaryButton}"
                                                        FontSize="11"
                                                        Click="ButtonJoinMatch_Click"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Private Lobby Card -->
                    <Border x:Name="BorderPrivateLobby"
                            Width="600"
                            Height="300"
                            BorderBrush="#00A896"
                            BorderThickness="1.5"
                            Background="#0B0E14"
                            CornerRadius="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Visibility="Collapsed">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#00A896" Opacity="0.7"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Private Card Header -->
                            <Border Grid.Row="0"
                                    BorderBrush="#00A896"
                                    BorderThickness="0,0,0,1.5"
                                    Background="#0B0E14"
                                    Padding="15,0">
                                <TextBlock Text="{DynamicResource Lobby_PrivateTitle}"
                                           FontFamily="{StaticResource GeistPixelSquare}"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="#4DEEEA"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Row="1" 
                                        VerticalAlignment="Center" 
                                        HorizontalAlignment="Center" 
                                        Width="320">
                                
                                <TextBlock Text="{DynamicResource Lobby_AccessCodeLabel}"
                                           Style="{StaticResource FormLabelStyle}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,10"/>

                                <Grid Height="40" Margin="0,0,0,4">
                                    <TextBox x:Name="TextBoxAccessCode"
                                             Style="{StaticResource ModernTextBox}"
                                             Height="40"
                                             TextChanged="TextBoxAccessCode_TextChanged"/>
                                    <TextBlock x:Name="TextBlockAccessCodePlaceholder"
                                               Text="{DynamicResource Lobby_AccessCodePlaceholder}"
                                               Style="{StaticResource PlaceholderStyle}"/>
                                </Grid>

                                <TextBlock x:Name="TextBlockAccessCodeError"
                                           Text="{DynamicResource Lobby_AccessCodeErrorLength}"
                                           Style="{StaticResource ErrorLabelStyle}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,15"/>

                                <Button x:Name="ButtonSearchLobby"
                                        Content="{DynamicResource Lobby_BtnSearch}"
                                        Width="220"
                                        Height="44"
                                        Style="{StaticResource ModernPrimaryButton}"
                                        HorizontalAlignment="Center"
                                        Click="ButtonSearchLobby_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Row 1: Bottom Navigation Bar Tray -->
            <Border Grid.Row="1"
                    BorderBrush="#00A896"
                    BorderThickness="0,1,0,0"
                    Background="#0B0E14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ButtonMainMenu"
                            Grid.Column="0"
                            Content="{DynamicResource Nav_MainMenu}"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonMainMenu_Click"/>

                    <Button x:Name="ButtonProfile"
                            Grid.Column="1"
                            Content="{DynamicResource Nav_Profile}"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonProfile_Click"/>

                    <Button x:Name="ButtonHistory"
                            Grid.Column="2"
                            Content="{DynamicResource Nav_History}"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonHistory_Click"/>

                    <Button x:Name="ButtonScoreboard"
                            Grid.Column="3"
                            Content="{DynamicResource Nav_Scoreboard}"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonScoreboard_Click"/>

                    <Button x:Name="ButtonSettings"
                            Grid.Column="4"
                            Content="{DynamicResource Nav_Settings}"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonSettings_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Hidden elements to preserve code-behind field references -->
        <Grid Visibility="Collapsed">
            <TextBlock x:Name="TextBlockUsername"/>
            <TextBlock x:Name="TextBlockAge"/>
            <Image x:Name="ImageUserAvatar"/>
        </Grid>
    </Grid>
</Page>
