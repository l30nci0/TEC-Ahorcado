<Page x:Class="LetterClashClient.Views.GUILobbyView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUILobbyView"
      Loaded="Page_Loaded">

    <Grid Background="#F4F4F4">
        <Border Margin="20"
            BorderBrush="#2B2B2B"
            BorderThickness="2"
            Background="White">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
              Margin="30,25,30,20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="105"/>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50*"/>
                            <ColumnDefinition Width="50*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                    Width="390"
                    Height="85"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image x:Name="ImageUserAvatar"
                        Grid.Column="0"
                        Source="/Assets/Images/UserAvatar.png"
                        Width="58"
                        Height="58"
                        Stretch="Uniform"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1"
                             VerticalAlignment="Center">

                                    <TextBlock x:Name="TextBlockUsername"
                              Text="&quot;NOMBRE DE USUARIO&quot;"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="#111111"
                              Margin="0,0,0,8"/>

                                    <TextBlock x:Name="TextBlockAge"
                              Text="&quot;EDAD&quot;"
                              FontSize="15"
                              FontWeight="SemiBold"
                              Foreground="#111111"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Image x:Name="ImageLogo"
                    Grid.Column="1"
                    Source="/Assets/Images/LogoLetterClash.jpeg"
                    Width="330"
                    Height="95"
                    Stretch="Uniform"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Tabs Menu -->
                    <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,5,0,0">
                        
                        <Button x:Name="ButtonTabPublic"
                                Content="Salas Públicas ◔"
                                Width="180"
                                Height="35"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Margin="0,0,10,0"
                                Cursor="Hand"
                                Click="ButtonTabPublic_Click"/>

                        <Button x:Name="ButtonTabPrivate"
                                Content="Unirse por Código 🔒"
                                Width="180"
                                Height="35"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="ButtonTabPrivate_Click"/>
                    </StackPanel>

                    <!-- Consolidated Content Lobbies -->
                    <Grid Grid.Row="2" Margin="0,15,0,0">
                        
                        <!-- Grid Public Lobby -->
                        <Border x:Name="BorderPublicLobby"
                                Width="850"
                                Height="340"
                                BorderBrush="#2B2B2B"
                                BorderThickness="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Visibility="Visible">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        BorderBrush="#2B2B2B"
                                        BorderThickness="0,0,0,1"
                                        Background="#F7F7F7">
                                    <Grid>
                                        <TextBlock Text="Lobbies en Linea"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="ButtonRefreshLobby"
                                                Content="Actualizar ⟳"
                                                Width="100"
                                                Height="25"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,15,0"
                                                Cursor="Hand"
                                                Click="ButtonRefreshLobby_Click"/>
                                    </Grid>
                                </Border>

                                <DataGrid x:Name="DataGridPublicMatches"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="All"
                                          FontSize="15"
                                          RowHeight="32"
                                          ColumnHeaderHeight="36">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Anfitrión"
                                                            Binding="{Binding NombreAnfitrion}"
                                                            Width="*"/>
                                        <DataGridTextColumn Header="Idioma"
                                                            Binding="{Binding Idioma}"
                                                            Width="*"/>
                                        <DataGridTextColumn Header="Privacidad"
                                                            Binding="{Binding Privacidad}"
                                                            Width="*"/>
                                        <DataGridTemplateColumn Header=""
                                                                Width="140">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Entrar   ➔"
                                                            Width="110"
                                                            Height="25"
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            Cursor="Hand"
                                                            Click="ButtonJoinMatch_Click"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- Grid Private Lobby -->
                        <Border x:Name="BorderPrivateLobby"
                                Width="650"
                                Height="340"
                                BorderBrush="#2B2B2B"
                                BorderThickness="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Visibility="Collapsed">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        BorderBrush="#2B2B2B"
                                        BorderThickness="0,0,0,1"
                                        Background="#F7F7F7">
                                    <TextBlock Text="Entrar en Lobby Privado"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <Grid Grid.Row="1"
                                      Margin="45,20,45,20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="45"/>
                                        <RowDefinition Height="45"/>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="70"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="Ingresa el Codigo de Acceso al Lobby"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               Foreground="#111111"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <Grid Grid.Row="1"
                                          Width="350"
                                          Height="35"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <TextBox x:Name="TextBoxAccessCode"
                                                 Height="35"
                                                 FontSize="15"
                                                 Padding="8,4"
                                                 TextChanged="TextBoxAccessCode_TextChanged"/>
                                        <TextBlock x:Name="TextBlockAccessCodePlaceholder"
                                                   Text="Código de acceso"
                                                   FontSize="15"
                                                   Foreground="#999999"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False"/>
                                    </Grid>

                                    <TextBlock x:Name="TextBlockAccessCodeError"
                                               Grid.Row="2"
                                               Text="Ingrese un código válido"
                                               FontSize="14"
                                               Foreground="Red"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Hidden"/>

                                    <Button x:Name="ButtonSearchLobby"
                                            Grid.Row="3"
                                            Content="Buscar Lobby     ⌕"
                                            Width="280"
                                            Height="45"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Cursor="Hand"
                                            Click="ButtonSearchLobby_Click"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Footer Menu -->
                <Border Grid.Row="1"
                BorderBrush="#2B2B2B"
                BorderThickness="0,2,0,0"
                Background="#F7F7F7">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ButtonMainMenu"
                    Grid.Column="0"
                    Content="Menu Principal  ⚔"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonMainMenu_Click"/>

                        <Button x:Name="ButtonProfile"
                    Grid.Column="1"
                    Content="Perfil  👤"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonProfile_Click"/>

                        <Button x:Name="ButtonHistory"
                    Grid.Column="2"
                    Content="Historial  ◴"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonHistory_Click"/>

                        <Button x:Name="ButtonScoreboard"
                    Grid.Column="3"
                    Content="Marcadores  🏆"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonScoreboard_Click"/>

                        <Button x:Name="ButtonSettings"
                    Grid.Column="4"
                    Content="Ajustes  ⚙"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonSettings_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
