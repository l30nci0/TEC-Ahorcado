<Page x:Class="LetterClashClient.Views.PublicLobby"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="PublicLobby"
      Loaded="Page_Loaded">

    <Grid Background="#F4F4F4">
        <Border Margin="20"
            BorderBrush="#2B2B2B"
            BorderThickness="2"
            Background="White">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
              Margin="30,25,30,20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="105"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50*"/>
                            <ColumnDefinition Width="50*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                    Width="390"
                    Height="85"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image x:Name="ImageUserAvatar"
                       Grid.Column="0"
                       Source="/Assets/Images/UserAvatar.png"
                       Width="58"
                       Height="58"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">

                                    <TextBlock x:Name="TextBlockUsername"
                             Text="&quot;NOMBRE DE USUARIO&quot;"
                             FontSize="16"
                             FontWeight="SemiBold"
                             Foreground="#111111"
                             Margin="0,0,0,8"/>

                                    <TextBlock x:Name="TextBlockAge"
                             Text="&quot;EDAD&quot;"
                             FontSize="15"
                             FontWeight="SemiBold"
                             Foreground="#111111"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Image x:Name="ImageLogo"
                   Grid.Column="1"
                   Source="/Assets/Images/LogoLetterClash.jpeg"
                   Width="330"
                   Height="95"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
                    </Grid>

                    <Border Grid.Row="1"
                  Width="850"
                  Height="360"
                  BorderBrush="#2B2B2B"
                  BorderThickness="1"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top"
                  Margin="0,20,0,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="45"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                      BorderBrush="#2B2B2B"
                      BorderThickness="0,0,0,1">

                                <TextBlock Text="Entrar a Lobby Publico"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                            </Border>

                            <Grid Grid.Row="1"
                    Margin="40,25,40,25">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                           Text="Partidas Iniciadas Actualmente"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#111111"
                           VerticalAlignment="Center"/>

                                <DataGrid x:Name="DataGridPublicMatches"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          FontSize="16"
                          RowHeight="38"
                          ColumnHeaderHeight="38"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Anfitrion"
                                        Binding="{Binding Host}"
                                        Width="*"/>

                                        <DataGridTextColumn Header="Idioma"
                                        Binding="{Binding Language}"
                                        Width="*"/>

                                        <DataGridTemplateColumn Header=""
                                            Width="230">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Unirse"
                                  Width="190"
                                  Height="30"
                                  FontSize="14"
                                  FontWeight="SemiBold"
                                  Cursor="Hand"
                                  Click="ButtonJoinMatch_Click"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                BorderBrush="#2B2B2B"
                BorderThickness="0,2,0,0"
                Background="#F7F7F7">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ButtonMainMenu"
                    Grid.Column="0"
                    Content="Menu Principal  ⚔"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonMainMenu_Click"/>

                        <Button x:Name="ButtonProfile"
                    Grid.Column="1"
                    Content="Perfil  👤"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonProfile_Click"/>

                        <Button x:Name="ButtonHistory"
                    Grid.Column="2"
                    Content="Historial  ◴"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonHistory_Click"/>

                        <Button x:Name="ButtonScoreboard"
                    Grid.Column="3"
                    Content="Marcadores  🏆"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonScoreboard_Click"/>

                        <Button x:Name="ButtonSettings"
                    Grid.Column="4"
                    Content="Ajustes  ⚙"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonSettings_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>