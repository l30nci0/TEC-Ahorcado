<Page x:Class="LetterClashClient.Views.GUISettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUISettingsView"
      Loaded="Page_Loaded"
      Background="#0B0E14">

    <Page.Resources>
        <!-- Retro Grayscale Primary Button Style -->
        <Style x:Key="ModernPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                                 <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00A896"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#181E29"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#52525B"/>
                                <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="0" ShadowDepth="0" Color="#000000" Opacity="0"/>
                                </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Retro Grayscale Secondary Button Style -->
        <Style x:Key="ModernSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#F649A7"/>
            <Setter Property="BorderBrush" Value="#E60067"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#9B004F" Opacity="0.6"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#F649A7"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F649A7"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#E60067"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E60067"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#181E29"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#52525B"/>
                                <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="0" ShadowDepth="0" Color="#000000" Opacity="0"/>
                                </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Bottom Navigation Bar Buttons -->
        <Style x:Key="NavBarButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="Transparent"
                                BorderThickness="0" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Foreground" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Foreground" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00A896"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#181E29"/>
                                <Setter TargetName="border" Property="Background" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#181E29"/>
                            </Trigger>
            </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form Elements Generic Styles -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00A896"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Modern Grid Line Background -->
        <Grid.Background>
            <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                <DrawingBrush.Drawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#15151A" Thickness="1"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,0" EndPoint="40,0"/>
                                <LineGeometry StartPoint="0,0" EndPoint="0,40"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </Grid.Background>

        <!-- Main Shell Grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Content Area -->
            <Grid Grid.Row="0">
                <!-- Main Card Container -->
                <Border Width="550"
                        Height="480"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        BorderBrush="#2D2D30"
                        BorderThickness="1.5"
                        Background="#0B0E14"
                        CornerRadius="0"
                        Padding="35">
                    <Border.Effect>
                        <DropShadowEffect x:Name="NeonGlow" Color="#00A896" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- Header -->
                            <RowDefinition Height="Auto"/>
                            <!-- Options stack -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header Section -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,25">
                            <TextBlock Text="AJUSTES"
                                       FontFamily="{StaticResource GeistPixelSquare}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#4DEEEA"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="Configura las preferencias de tu perfil y juego"
                                       FontFamily="{StaticResource GeistMono}"
                                       FontSize="13"
                                       Foreground="#4DEEEA"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Settings Panel Stack -->
                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <!-- Privacy settings -->
                            <Button x:Name="ButtonPrivacy"
                                    Content="Perfil: Publico          🔒"
                                    Height="45"
                                    Style="{StaticResource ModernSecondaryButton}"
                                    Margin="0,0,0,15"
                                    Click="ButtonPrivacy_Click"/>

                            <!-- Sound settings -->
                            <Button x:Name="ButtonSound"
                                    Content="Sonido                 ≋"
                                    Height="45"
                                    Style="{StaticResource ModernSecondaryButton}"
                                    Margin="0,0,0,15"
                                    Click="ButtonSound_Click"/>

                            <!-- How to play instructions -->
                            <Button x:Name="ButtonHowToPlay"
                                    Content="Como Jugar??          ?"
                                    Height="45"
                                    Style="{StaticResource ModernSecondaryButton}"
                                    Margin="0,0,0,15"
                                    Click="ButtonHowToPlay_Click"/>

                            <!-- Segmented Language selector -->
                            <StackPanel Margin="0,5,0,20">
                                <TextBlock Text="IDIOMA PREFERIDO" Style="{StaticResource FormLabelStyle}"/>
                                <Grid Height="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Button x:Name="ButtonLangES"
                                            Grid.Column="0"
                                            Content="ESPAÑOL"
                                            Style="{StaticResource ModernPrimaryButton}"
                                            Margin="0,0,5,0"
                                            Click="ButtonLangES_Click"/>
                                            
                                    <Button x:Name="ButtonLangEN"
                                            Grid.Column="1"
                                            Content="ENGLISH"
                                            Style="{StaticResource ModernSecondaryButton}"
                                            Margin="5,0,0,0"
                                            Click="ButtonLangEN_Click"/>
                                </Grid>
                            </StackPanel>

                            <!-- Logout button -->
                            <Button x:Name="ButtonLogout"
                                    Content="Cerrar Sesion          ↩"
                                    Height="45"
                                    Style="{StaticResource ModernSecondaryButton}"
                                    Click="ButtonLogout_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 1: Bottom Navigation Bar Tray -->
            <Border Grid.Row="1"
                    BorderBrush="#2D2D30"
                    BorderThickness="0,1,0,0"
                    Background="#121214">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ButtonMainMenu"
                            Grid.Column="0"
                            Content="Menu Principal  ⚔"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonMainMenu_Click"/>

                    <Button x:Name="ButtonProfile"
                            Grid.Column="1"
                            Content="Perfil  👤"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonProfile_Click"/>

                    <Button x:Name="ButtonHistory"
                            Grid.Column="2"
                            Content="Historial  ◴"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonHistory_Click"/>

                    <Button x:Name="ButtonScoreboard"
                            Grid.Column="3"
                            Content="Marcadores  🏆"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonScoreboard_Click"/>

                    <Button x:Name="ButtonSettings"
                            Grid.Column="4"
                            Content="Ajustes  ⚙"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonSettings_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Hidden elements to preserve code-behind field references -->
        <Grid Visibility="Collapsed">
            <ComboBox x:Name="ComboBoxPreferredLanguage">
                <ComboBoxItem Content="Español"/>
                <ComboBoxItem Content="Ingles"/>
            </ComboBox>
            <Image x:Name="ImageLogo"/>
            <Image x:Name="ImageHangman"/>
        </Grid>
    </Grid>
</Page>
