<Page x:Class="LetterClashClient.Views.GUIMainMenuView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:LetterClashClient.Controls"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUIMainMenuView"
      Loaded="Page_Loaded"
      Background="#09090B">

    <Page.Resources>
        <!-- Retro Grayscale Primary Button Style -->
        <Style x:Key="ModernPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E4E4E7"/>
            <Setter Property="Foreground" Value="#09090B"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#D4D4D8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#71717A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Retro Grayscale Secondary Button Style -->
        <Style x:Key="ModernSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="BorderBrush" Value="#2D2D30"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#27272A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F4F4F5"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#09090B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="BorderBrush" Value="#09090B"/>
                                <Setter Property="Foreground" Value="#52525B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Bottom Navigation Bar Buttons -->
        <Style x:Key="NavBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="Transparent"
                                BorderThickness="0" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="border" Property="Background" Value="#1E1E21"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#09090B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Animated Pixel Starfield Background -->
        <controls:StarfieldBackground Panel.ZIndex="0"/>

        <!-- Main Shell Grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Content Area (Minecraft style) -->
            <StackPanel Grid.Row="0" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Center" 
                        Width="400">

                <!-- Large Rectangular Logo at the very top -->
                <Image x:Name="ImageLogo"
                       Source="/Assets/Images/LogoLetterClashRectangle.png"
                       Width="380"
                       Height="180"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30">
                    <Image.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="4" Color="#000000" Opacity="0.6"/>
                    </Image.Effect>
                </Image>

                <!-- Vertical Buttons Stack -->
                <Button x:Name="ButtonCreateRoom"
                        Content="CREAR SALA ✎"
                        Style="{StaticResource ModernPrimaryButton}"
                        Height="48"
                        Margin="0,0,0,16"
                        Click="ButtonCreateRoom_Click"/>

                <Button x:Name="ButtonPublicLobby"
                        Content="ENTRAR A LOBBY PÚBLICO ◔"
                        Style="{StaticResource ModernSecondaryButton}"
                        Height="48"
                        Margin="0,0,0,16"
                        Click="ButtonPublicLobby_Click"/>

                <Button x:Name="ButtonPrivateLobby"
                        Content="ENTRAR A LOBBY PRIVADO 🔒"
                        Style="{StaticResource ModernSecondaryButton}"
                        Height="48"
                        Click="ButtonPrivateLobby_Click"/>
            </StackPanel>

            <!-- Row 1: Bottom Navigation Bar Tray -->
            <Border Grid.Row="1"
                    BorderBrush="#2D2D30"
                    BorderThickness="0,1,0,0"
                    Background="#121214">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ButtonMainMenu"
                            Grid.Column="0"
                            Content="Menu Principal  ⚔"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonMainMenu_Click"/>

                    <Button x:Name="ButtonProfile"
                            Grid.Column="1"
                            Content="Perfil  👤"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonProfile_Click"/>

                    <Button x:Name="ButtonHistory"
                            Grid.Column="2"
                            Content="Historial  ◴"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonHistory_Click"/>

                    <Button x:Name="ButtonScoreboard"
                            Grid.Column="3"
                            Content="Marcadores  🏆"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonScoreboard_Click"/>

                    <Button x:Name="ButtonSettings"
                            Grid.Column="4"
                            Content="Ajustes  ⚙"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonSettings_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Hidden elements to preserve code-behind field references -->
        <Grid Visibility="Collapsed">
            <TextBlock x:Name="TextBlockUsername"/>
            <TextBlock x:Name="TextBlockAge"/>
            <Image x:Name="ImageUserAvatar"/>
            <Image x:Name="ImageHangman"/>
        </Grid>
    </Grid>
</Page>
