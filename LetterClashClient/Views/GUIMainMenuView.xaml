<Page x:Class="LetterClashClient.Views.GUIMainMenuView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUIMainMenuView"
      Loaded="Page_Loaded">

    <Grid Background="#F4F4F4">
        <Border Margin="20"
            BorderBrush="#2B2B2B"
            BorderThickness="2"
            Background="White">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
              Margin="30,25,30,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42*"/>
                        <ColumnDefinition Width="58*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="95"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    Width="390"
                    Height="85"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image x:Name="ImageUserAvatar"
                        Grid.Column="0"
                        Source="/Assets/Images/UserAvatar.png"
                        Width="58"
                        Height="58"
                        Stretch="Uniform"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1"
                             VerticalAlignment="Center">

                                    <TextBlock x:Name="TextBlockUsername"
                              Text="&quot;NOMBRE DE USUARIO&quot;"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="#111111"
                              Margin="0,0,0,8"/>

                                    <TextBlock x:Name="TextBlockAge"
                              Text="&quot;EDAD&quot;"
                              FontSize="15"
                              FontWeight="SemiBold"
                              Foreground="#111111"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                    Width="520"
                    Height="350"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                            <Grid Margin="25">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="100"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Button x:Name="ButtonCreateRoom"
                        Grid.Row="0"
                        Content="Crear Sala        ✎"
                        Width="370"
                        Height="55"
                        FontSize="16"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Click="ButtonCreateRoom_Click"/>

                                <Border Grid.Row="1"
                        BorderBrush="#2B2B2B"
                        BorderThickness="1"
                        Margin="0,10,0,0">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                               Text="⌕"
                               FontSize="46"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#1E1E2F"/>

                                        <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">

                                            <Button x:Name="ButtonPublicLobby"
                               Content="Entrar a Lobby Publico     ◔"
                               Width="370"
                               Height="52"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20"
                               Cursor="Hand"
                               Click="ButtonPublicLobby_Click"/>

                                            <Button x:Name="ButtonPrivateLobby"
                               Content="Entrar a Lobby Privado     🔒"
                               Width="370"
                               Height="52"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Cursor="Hand"
                               Click="ButtonPrivateLobby_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="110"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="70"/>
                        </Grid.RowDefinitions>

                        <Image x:Name="ImageLogo"
                    Grid.Row="0"
                    Source="/Assets/Images/LogoLetterClash.jpeg"
                    Width="330"
                    Height="95"
                    Stretch="Uniform"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                        <Image x:Name="ImageHangman"
                    Grid.Row="1"
                    Width="280"
                    Height="320"
                    Stretch="Uniform"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                        <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                            <Button x:Name="ButtonRemovePart"
                       Content="Quitar"
                       Width="90"
                       Height="35"
                       FontSize="15"
                       Margin="0,0,20,0"
                       Cursor="Hand"
                       Click="ButtonRemovePart_Click"/>

                            <Button x:Name="ButtonAddPart"
                       Content="Agregar"
                       Width="90"
                       Height="35"
                       FontSize="15"
                       Cursor="Hand"
                       Click="ButtonAddPart_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <Border Grid.Row="1"
                BorderBrush="#2B2B2B"
                BorderThickness="0,2,0,0"
                Background="#F7F7F7">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ButtonMainMenu"
                    Grid.Column="0"
                    Content="Menu Principal  ⚔"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonMainMenu_Click"/>

                        <Button x:Name="ButtonProfile"
                    Grid.Column="1"
                    Content="Perfil  👤"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonProfile_Click"/>

                        <Button x:Name="ButtonHistory"
                    Grid.Column="2"
                    Content="Historial  ◴"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonHistory_Click"/>

                        <Button x:Name="ButtonScoreboard"
                    Grid.Column="3"
                    Content="Marcadores  🏆"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonScoreboard_Click"/>

                        <Button x:Name="ButtonSettings"
                    Grid.Column="4"
                    Content="Ajustes  ⚙"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonSettings_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
