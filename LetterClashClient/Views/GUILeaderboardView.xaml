<Page x:Class="LetterClashClient.Views.GUILeaderboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:LetterClashClient.Controls"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUILeaderboardView"
      Loaded="Page_Loaded"
      Background="#09090B">

    <Page.Resources>
        <!-- Style for Bottom Navigation Bar Buttons -->
        <Style x:Key="NavBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="Transparent"
                                BorderThickness="0" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="border" Property="Background" Value="#1E1E21"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#09090B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Dark Grayscale Styles -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#09090B"/>
            <Setter Property="BorderBrush" Value="#2D2D30"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1F1F23"/>
            <Setter Property="VerticalGridLinesBrush" Value="#1F1F23"/>
            <Setter Property="RowBackground" Value="#0E0E10"/>
            <Setter Property="AlternatingRowBackground" Value="#141417"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#2D2D30"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#27272A"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderBrush" Value="#2D2D30"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <!-- Form Elements Generic Styles -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Animated Pixel Starfield Background -->
        <controls:StarfieldBackground Panel.ZIndex="0"/>

        <!-- Main Shell Grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Content Area -->
            <Grid Grid.Row="0">
                <!-- Main Card Container -->
                <Border Width="980"
                        Height="520"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        BorderBrush="#2D2D30"
                        BorderThickness="1.5"
                        Background="#121214"
                        CornerRadius="0"
                        Padding="30">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="#000000" Opacity="0.5"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- Header -->
                            <RowDefinition Height="Auto"/>
                            <!-- Content -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header Section -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="MARCADORES"
                                       FontFamily="{StaticResource GeistPixelSquare}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#FFFFFF"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4"/>

                            <TextBlock Text="Los 50 mejores jugadores globales y líderes de la temporada"
                                       FontFamily="{StaticResource GeistMono}"
                                       FontSize="13"
                                       Foreground="#A1A1AA"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Main Content Grid -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <!-- Scoreboard Grid (Left) -->
                                <ColumnDefinition Width="1.3*"/>
                                <!-- Divider -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Podium (Right) -->
                                <ColumnDefinition Width="0.7*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Column: DataGrid -->
                            <DataGrid x:Name="DataGridScoreboard"
                                      Grid.Column="0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      Background="#09090B"
                                      Margin="0,0,25,0"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      MouseDoubleClick="DataGridScoreboard_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="PUESTO"
                                                        Binding="{Binding Puesto}"
                                                        Width="75"/>

                                    <DataGridTextColumn Header="JUGADOR"
                                                        Binding="{Binding Nombre}"
                                                        Width="*"/>

                                    <DataGridTextColumn Header="VICTORIAS"
                                                        Binding="{Binding PartidasGanadas}"
                                                        Width="95"/>

                                    <DataGridTextColumn Header="PUNTUACIÓN"
                                                        Binding="{Binding Puntuacion}"
                                                        Width="105"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Vertical Divider -->
                            <Border Grid.Column="1" Width="1.5" Background="#2D2D30" VerticalAlignment="Stretch" Margin="0,5"/>

                            <!-- Right Column: Podium -->
                            <StackPanel Grid.Column="2" Margin="25,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="PODIO DE LÍDERES" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                                <!-- First Place Card -->
                                <Border BorderBrush="#E4E4E7" BorderThickness="1.5" Background="#18181B" Padding="12,10" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="1"
                                                   FontFamily="{StaticResource GeistPixelSquare}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>

                                        <Border Grid.Column="1" Width="40" Height="40" BorderBrush="#2D2D30" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Image x:Name="ImageTopAvatar1" Stretch="UniformToFill"/>
                                        </Border>

                                        <TextBlock x:Name="TextBlockTopName1"
                                                   Grid.Column="2"
                                                   Text="-"
                                                   FontFamily="{StaticResource GeistMono}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"
                                                   Margin="15,0,0,0"/>
                                    </Grid>
                                </Border>

                                <!-- Second Place Card -->
                                <Border BorderBrush="#2D2D30" BorderThickness="1" Background="#0E0E10" Padding="12,8" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="2"
                                                   FontFamily="{StaticResource GeistPixelSquare}"
                                                   FontSize="20"
                                                   Foreground="#A1A1AA"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>

                                        <Border Grid.Column="1" Width="36" Height="36" BorderBrush="#2D2D30" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Image x:Name="ImageTopAvatar2" Stretch="UniformToFill"/>
                                        </Border>

                                        <TextBlock x:Name="TextBlockTopName2"
                                                   Grid.Column="2"
                                                   Text="-"
                                                   FontFamily="{StaticResource GeistMono}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#E4E4E7"
                                                   VerticalAlignment="Center"
                                                   Margin="15,0,0,0"/>
                                    </Grid>
                                </Border>

                                <!-- Third Place Card -->
                                <Border BorderBrush="#2D2D30" BorderThickness="1" Background="#0E0E10" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="3"
                                                   FontFamily="{StaticResource GeistPixelSquare}"
                                                   FontSize="20"
                                                   Foreground="#71717A"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>

                                        <Border Grid.Column="1" Width="36" Height="36" BorderBrush="#2D2D30" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Image x:Name="ImageTopAvatar3" Stretch="UniformToFill"/>
                                        </Border>

                                        <TextBlock x:Name="TextBlockTopName3"
                                                   Grid.Column="2"
                                                   Text="-"
                                                   FontFamily="{StaticResource GeistMono}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#E4E4E7"
                                                   VerticalAlignment="Center"
                                                   Margin="15,0,0,0"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 1: Bottom Navigation Bar Tray -->
            <Border Grid.Row="1"
                    BorderBrush="#2D2D30"
                    BorderThickness="0,1,0,0"
                    Background="#121214">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ButtonMainMenu"
                            Grid.Column="0"
                            Content="Menu Principal  ⚔"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonMainMenu_Click"/>

                    <Button x:Name="ButtonProfile"
                            Grid.Column="1"
                            Content="Perfil  👤"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonProfile_Click"/>

                    <Button x:Name="ButtonHistory"
                            Grid.Column="2"
                            Content="Historial  ◴"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonHistory_Click"/>

                    <Button x:Name="ButtonScoreboard"
                            Grid.Column="3"
                            Content="Marcadores  🏆"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonScoreboard_Click"/>

                    <Button x:Name="ButtonSettings"
                            Grid.Column="4"
                            Content="Ajustes  ⚙"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonSettings_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Hidden elements to preserve code-behind field references -->
        <Grid Visibility="Collapsed">
            <Image x:Name="ImageStarHeader"/>
            <Image x:Name="ImageStarLeft"/>
            <Image x:Name="ImageStarRight"/>
            <Image x:Name="ImageLogo"/>
        </Grid>
    </Grid>
</Page>
