<Page x:Class="LetterClashClient.Views.Scoreboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="Scoreboard"
      Loaded="Page_Loaded">

    <Grid Background="#F4F4F4">
        <Border Margin="20"
            BorderBrush="#2B2B2B"
            BorderThickness="2"
            Background="White">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
              Margin="30,25,30,15">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="235"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45*"/>
                            <ColumnDefinition Width="55*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                    Width="450"
                    Height="80"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="85"/>
                                </Grid.ColumnDefinitions>

                                <Image x:Name="ImageStarHeader"
                       Grid.Column="0"
                       Source="/Assets/Images/star.png"
                       Width="56"
                       Height="56"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                           Text="Mejores Puntajes"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#111111"
                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="2"
                           Text="◔"
                           FontSize="44"
                           Foreground="#333333"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Image x:Name="ImageLogo"
                   Grid.Column="1"
                   Source="/Assets/Images/LogoLetterClash.jpeg"
                   Width="330"
                   Height="95"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18*"/>
                            <ColumnDefinition Width="22*"/>
                            <ColumnDefinition Width="22*"/>
                            <ColumnDefinition Width="22*"/>
                            <ColumnDefinition Width="18*"/>
                        </Grid.ColumnDefinitions>

                        <Image x:Name="ImageStarLeft"
                   Grid.Column="0"
                   Source="/Assets/Images/star.png"
                   Width="62"
                   Height="62"
                   Stretch="Uniform"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Bottom"
                   Margin="10,0,0,25"/>

                        <StackPanel Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,50">

                            <TextBlock Text="Usuario 3"
                         FontSize="21"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,8"/>

                            <Border Width="130"
                      Height="125"
                      BorderBrush="#2B2B2B"
                      BorderThickness="1">

                                <Grid>
                                    <TextBlock Text="3"
                             FontSize="24"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Margin="0,12,0,0"/>

                                    <Image x:Name="ImageTopAvatar3"
                         Source="/Assets/Images/UserAvatar.png"
                         Width="62"
                         Height="62"
                         Stretch="Uniform"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Bottom"
                         Margin="0,0,0,15"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,5,0,0">

                            <TextBlock Text="Usuario 1"
                         FontSize="21"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,8"/>

                            <Border Width="130"
                      Height="150"
                      BorderBrush="#2B2B2B"
                      BorderThickness="1">

                                <Grid>
                                    <TextBlock Text="1"
                             FontSize="24"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Margin="0,18,0,0"/>

                                    <Image x:Name="ImageTopAvatar1"
                         Source="/Assets/Images/UserAvatar.png"
                         Width="66"
                         Height="66"
                         Stretch="Uniform"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Bottom"
                         Margin="0,0,0,18"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,55">

                            <TextBlock Text="Usuario 2"
                         FontSize="21"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,8"/>

                            <Border Width="130"
                      Height="135"
                      BorderBrush="#2B2B2B"
                      BorderThickness="1">

                                <Grid>
                                    <TextBlock Text="2"
                             FontSize="24"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Margin="0,14,0,0"/>

                                    <Image x:Name="ImageTopAvatar2"
                         Source="/Assets/Images/UserAvatar.png"
                         Width="64"
                         Height="64"
                         Stretch="Uniform"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Bottom"
                         Margin="0,0,0,16"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Image x:Name="ImageStarRight"
                   Grid.Column="4"
                   Source="/Assets/Images/star.png"
                   Width="62"
                   Height="62"
                   Stretch="Uniform"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,10,25"/>

                        <TextBlock Grid.Column="1"
                       Grid.ColumnSpan="3"
                       Text="Mejores 50 Posiciones"
                       FontSize="23"
                       FontWeight="SemiBold"
                       Foreground="#1E1E2F"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,5"/>
                    </Grid>

                    <DataGrid x:Name="DataGridScoreboard"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      FontSize="15"
                      RowHeight="32"
                      ColumnHeaderHeight="36"
                      Margin="55,5,55,0"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      MouseDoubleClick="DataGridScoreboard_MouseDoubleClick">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nombre"
                                  Binding="{Binding Nombre}"
                                  Width="*"/>

                            <DataGridTextColumn Header="Partidas Ganadas"
                                  Binding="{Binding PartidasGanadas}"
                                  Width="*"/>

                            <DataGridTextColumn Header="Porcentaje"
                                  Binding="{Binding Porcentaje}"
                                  Width="*"/>

                            <DataGridTextColumn Header="Puntuación"
                                  Binding="{Binding Puntuacion}"
                                  Width="*"/>

                            <DataGridTextColumn Header="Puesto"
                                  Binding="{Binding Puesto}"
                                  Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Border Grid.Row="1"
                BorderBrush="#2B2B2B"
                BorderThickness="0,2,0,0"
                Background="#F7F7F7">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ButtonMainMenu"
                    Grid.Column="0"
                    Content="Menu Principal  ⚔"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonMainMenu_Click"/>

                        <Button x:Name="ButtonProfile"
                    Grid.Column="1"
                    Content="Perfil  👤"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonProfile_Click"/>

                        <Button x:Name="ButtonHistory"
                    Grid.Column="2"
                    Content="Historial  ◴"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonHistory_Click"/>

                        <Button x:Name="ButtonScoreboard"
                    Grid.Column="3"
                    Content="Marcadores  🏆"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonScoreboard_Click"/>

                        <Button x:Name="ButtonSettings"
                    Grid.Column="4"
                    Content="Ajustes  ⚙"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonSettings_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>