<Page x:Class="LetterClashClient.Views.GUIHistoryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUIHistoryView"
      Loaded="OnPaginaCargada"
      Background="#0B0E14">

    <Page.Resources>
        <!-- Style for Bottom Navigation Bar Buttons -->
        <Style x:Key="NavBarButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Foreground" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Foreground" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Avatar Clip for circular images -->
        <Style x:Key="CircularAvatarStyle" TargetType="Image">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Stretch" Value="UniformToFill"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Card Style for SF6-style Match Card -->
        <Style x:Key="MatchCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Player Name Style -->
        <Style x:Key="PlayerNameStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Modern Grid Line Background -->
        <Grid.Background>
            <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                <DrawingBrush.Drawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#15151A" Thickness="1"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,0" EndPoint="40,0"/>
                                <LineGeometry StartPoint="0,0" EndPoint="0,40"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </Grid.Background>

        <!-- Main Shell Grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Content Area with Scroll -->
            <Grid Grid.Row="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="40,20">
                    <StackPanel>
                        <!-- Header Section -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="{DynamicResource History_Title}"
                                       FontFamily="{StaticResource GeistPixelSquare}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#4DEEEA"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4"/>

                            <TextBlock Text="{DynamicResource History_Subtitle}"
                                       FontFamily="{StaticResource GeistMono}"
                                       FontSize="13"
                                       Foreground="#4DEEEA"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Profile Bar: Mini avatar + stats -->
                        <Border BorderBrush="#4DEEEA" BorderThickness="1" Background="#0B0E14" Padding="20,14" Margin="0,0,0,20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#4DEEEA" Opacity="0.4"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Mini avatar + username -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,25,0">
                                    <Border Width="56" Height="56" BorderBrush="#4DEEEA" BorderThickness="1.5" CornerRadius="28" Background="#0B0E14" HorizontalAlignment="Center">
                                        <Grid>
                                            <Ellipse Fill="#0B0E14"/>
                                            <Image x:Name="ImageUserAvatar" Width="52" Height="52" Stretch="UniformToFill">
                                                <Image.Clip>
                                                    <EllipseGeometry Center="26,26" RadiusX="26" RadiusY="26"/>
                                                </Image.Clip>
                                            </Image>
                                        </Grid>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#4DEEEA" Opacity="0.4"/>
                                        </Border.Effect>
                                    </Border>
                                    <TextBlock x:Name="TextBlockUsername" FontFamily="{StaticResource GeistPixelSquare}" FontSize="12" Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                </StackPanel>

                                <!-- Stats row -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock x:Name="TextBlockTotalWins" FontFamily="{StaticResource GeistMono}" FontSize="13" Foreground="#22C55E" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TextBlockPercentWins" FontFamily="{StaticResource GeistMono}" FontSize="11" Foreground="#22C55E" HorizontalAlignment="Center" Opacity="0.7"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock x:Name="TextBlockTotalLosses" FontFamily="{StaticResource GeistMono}" FontSize="13" Foreground="#EF4444" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TextBlockPercentLosses" FontFamily="{StaticResource GeistMono}" FontSize="11" Foreground="#EF4444" HorizontalAlignment="Center" Opacity="0.7"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock x:Name="TextBlockTotalDisconnected" FontFamily="{StaticResource GeistMono}" FontSize="13" Foreground="#A1A1AA" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TextBlockPercentDisconnected" FontFamily="{StaticResource GeistMono}" FontSize="11" Foreground="#A1A1AA" HorizontalAlignment="Center" Opacity="0.7"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- SF6-style Match Cards List -->
                        <ItemsControl x:Name="ItemsControlHistory">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource MatchCardStyle}">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#4DEEEA" Opacity="0.3"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="1.5*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Player 1 (Current User) -->
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border Width="64" Height="64" BorderBrush="#4DEEEA" BorderThickness="1.5" CornerRadius="32" Background="#0B0E14" HorizontalAlignment="Center">
                                                    <Grid>
                                                        <Ellipse Fill="#0B0E14"/>
                                                        <Image Width="60" Height="60" Stretch="UniformToFill" Source="{Binding AvatarUsuario}">
                                                            <Image.Clip>
                                                                <EllipseGeometry Center="30,30" RadiusX="30" RadiusY="30"/>
                                                            </Image.Clip>
                                                        </Image>
                                                    </Grid>
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#4DEEEA" Opacity="0.3"/>
                                                    </Border.Effect>
                                                </Border>
                                                <TextBlock Text="{Binding NombreUsuario}" Style="{StaticResource PlayerNameStyle}" Margin="0,8,0,0"/>
                                                <TextBlock Text="{Binding RolUsuario}" FontFamily="{StaticResource GeistMono}" FontSize="10" Foreground="#A1A1AA" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Center: VS / Result / Date -->
                                            <Border Grid.Column="1" Width="120" VerticalAlignment="Center" Margin="12,0">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <!-- VS Badge -->
                                                    <Border BorderBrush="#4DEEEA" BorderThickness="1" Background="#0B0E14" Padding="12,4" Margin="0,0,0,8" HorizontalAlignment="Center">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#4DEEEA" Opacity="0.5"/>
                                                        </Border.Effect>
                                                        <TextBlock Text="VS" FontFamily="{StaticResource GeistPixelSquare}" FontSize="18" FontWeight="Bold" Foreground="#4DEEEA" HorizontalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Result Badge -->
                                                    <Border BorderThickness="1" Padding="10,4" HorizontalAlignment="Center" CornerRadius="2" Margin="0,0,0,6">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#0B0E14"/>
                                                                <Setter Property="BorderBrush" Value="#A1A1AA"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Resultado}" Value="Victoria">
                                                                        <Setter Property="Background" Value="#22C55E"/>
                                                                        <Setter Property="BorderBrush" Value="#22C55E"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Resultado}" Value="Derrota">
                                                                        <Setter Property="Background" Value="#EF4444"/>
                                                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Resultado}" Value="Loss">
                                                                        <Setter Property="Background" Value="#EF4444"/>
                                                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Resultado}" Value="Desconectada">
                                                                        <Setter Property="Background" Value="#52525B"/>
                                                                        <Setter Property="BorderBrush" Value="#52525B"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Resultado}" Value="Disconnected">
                                                                        <Setter Property="Background" Value="#52525B"/>
                                                                        <Setter Property="BorderBrush" Value="#52525B"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Resultado}" FontFamily="{StaticResource GeistPixelSquare}" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Puntuacion -->
                                                    <TextBlock Text="{Binding Puntuacion}" FontFamily="{StaticResource GeistPixelSquare}" FontSize="15" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,4"/>

                                                    <!-- Date -->
                                                    <TextBlock Text="{Binding Fecha}" FontFamily="{StaticResource GeistMono}" FontSize="10" Foreground="#A1A1AA" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Player 2 (Rival) -->
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border Width="64" Height="64" BorderBrush="#F649A7" BorderThickness="1.5" CornerRadius="32" Background="#0B0E14" HorizontalAlignment="Center">
                                                    <Grid>
                                                        <Ellipse Fill="#0B0E14"/>
                                                        <Image Width="60" Height="60" Stretch="UniformToFill" Source="{Binding AvatarRival}">
                                                            <Image.Clip>
                                                                <EllipseGeometry Center="30,30" RadiusX="30" RadiusY="30"/>
                                                            </Image.Clip>
                                                        </Image>
                                                    </Grid>
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#F649A7" Opacity="0.3"/>
                                                    </Border.Effect>
                                                </Border>
                                                <TextBlock Text="{Binding Rival}" Style="{StaticResource PlayerNameStyle}" Margin="0,8,0,0"/>
                                                <TextBlock Text="{Binding RolRival}" FontFamily="{StaticResource GeistMono}" FontSize="10" Foreground="#A1A1AA" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Row 1: Bottom Navigation Bar Tray -->
            <Border Grid.Row="1"
                    BorderBrush="#00A986"
                    BorderThickness="0,1,0,0"
                    Background="#0B0E14">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#4DEEEA" Opacity="0.6"/>
                    </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ButtonMainMenu"
                            Grid.Column="0"
                            Content="{DynamicResource Nav_MainMenu}"
                            Style="{StaticResource NavBarButton}"
                            Click="OnClicMenuPrincipal"/>

                    <Button x:Name="ButtonProfile"
                            Grid.Column="1"
                            Content="{DynamicResource Nav_Profile}"
                            Style="{StaticResource NavBarButton}"
                            Click="OnClicPerfil"/>

                    <Button x:Name="ButtonHistory"
                            Grid.Column="2"
                            Content="{DynamicResource Nav_History}"
                            Style="{StaticResource NavBarButton}"
                            Click="OnClicHistorial"/>

                    <Button x:Name="ButtonScoreboard"
                            Grid.Column="3"
                            Content="{DynamicResource Nav_Scoreboard}"
                            Style="{StaticResource NavBarButton}"
                            Click="OnClicMarcadores"/>

                    <Button x:Name="ButtonSettings"
                            Grid.Column="4"
                            Content="{DynamicResource Nav_Settings}"
                            Style="{StaticResource NavBarButton}"
                            Click="OnClicAjustes"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Hidden elements to preserve code-behind field references -->
        <Grid Visibility="Collapsed">
            <Image x:Name="ImageStatistics"/>
            <Image x:Name="ImageLogo"/>
            <TextBlock x:Name="TextBlockAge"/>
        </Grid>
    </Grid>
</Page>