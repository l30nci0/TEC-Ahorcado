<Page x:Class="LetterClashClient.Views.Profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="Profile"
      Loaded="Page_Loaded">

    <Grid Background="#F4F4F4">
        <Border Margin="20"
            BorderBrush="#2B2B2B"
            BorderThickness="2"
            Background="White">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
              Margin="25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52*"/>
                        <ColumnDefinition Width="48*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                    Width="260"
                    Height="55"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">

                            <Grid>
                                <TextBlock x:Name="TextBlockUsernameHeader"
                           Text="&quot;NOMBRE DE USUARIO&quot;"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#111111"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                    Width="560"
                    Height="330"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">

                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                             Text="Nombre:"
                             FontSize="17"
                             Foreground="#111111"
                             VerticalAlignment="Center"/>

                                    <TextBlock x:Name="TextBlockFullName"
                             Grid.Column="1"
                             FontSize="17"
                             Foreground="#111111"
                             VerticalAlignment="Center"
                             TextDecorations="Underline"/>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                             Text="Edad:"
                             FontSize="17"
                             Foreground="#111111"
                             VerticalAlignment="Center"/>

                                    <TextBlock x:Name="TextBlockAge"
                             Grid.Column="1"
                             FontSize="17"
                             Foreground="#111111"
                             VerticalAlignment="Center"
                             TextDecorations="Underline"/>

                                    <TextBlock Grid.Column="2"
                             Text="Cumple:"
                             FontSize="17"
                             Foreground="#111111"
                             VerticalAlignment="Center"/>

                                    <TextBlock x:Name="TextBlockBirthDate"
                             Grid.Column="3"
                             FontSize="17"
                             Foreground="#111111"
                             VerticalAlignment="Center"
                             TextDecorations="Underline"/>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="145"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                             Text="Correo Electrónico:"
                             FontSize="17"
                             Foreground="#111111"
                             VerticalAlignment="Center"/>

                                    <TextBlock x:Name="TextBlockEmail"
                             Grid.Column="1"
                             FontSize="17"
                             Foreground="#111111"
                             VerticalAlignment="Center"
                             TextDecorations="Underline"/>
                                </Grid>

                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                             Text="Teléfono:"
                             FontSize="17"
                             Foreground="#111111"
                             VerticalAlignment="Center"/>

                                    <TextBlock x:Name="TextBlockPhone"
                             Grid.Column="1"
                             FontSize="17"
                             Foreground="#111111"
                             VerticalAlignment="Center"
                             TextDecorations="Underline"/>
                                </Grid>

                                <Button x:Name="ButtonEdit"
                        Grid.Row="4"
                        Content="Editar  🛠"
                        Width="160"
                        Height="38"
                        FontSize="16"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Cursor="Hand"
                        Click="ButtonEdit_Click"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="110"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Image x:Name="ImageLogo"
                   Grid.Row="0"
                   Source="/Assets/Images/LogoLetterClash.jpeg"
                   Width="320"
                   Height="95"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

                        <Canvas x:Name="CanvasHangmanProfile"
                    Grid.Row="1"
                    Width="320"
                    Height="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                            <Image x:Name="ImageHangman"
                     Source="/Assets/Images/Hangedman1.jpg"
                     Width="280"
                     Height="320"
                     Stretch="Uniform"
                     Canvas.Left="20"
                     Canvas.Top="20"/>

                            <Border x:Name="BorderUserAvatar"
                      Width="72"
                      Height="72"
                      CornerRadius="36"
                      BorderBrush="#2B2B2B"
                      BorderThickness="2"
                      Background="White"
                      Canvas.Left="195"
                      Canvas.Top="83">

                                <Image x:Name="ImageUserAvatar"
                       Source="/Assets/Images/UserAvatar.png"
                       Width="58"
                       Height="58"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                            </Border>
                        </Canvas>
                    </Grid>
                </Grid>

                <Border Grid.Row="1"
                BorderBrush="#2B2B2B"
                BorderThickness="0,2,0,0"
                Background="#F7F7F7">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ButtonMainMenu"
                    Grid.Column="0"
                    Content="Menu Principal  ⚔"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonMainMenu_Click"/>

                        <Button x:Name="ButtonProfile"
                    Grid.Column="1"
                    Content="Perfil  👤"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonProfile_Click"/>

                        <Button x:Name="ButtonHistory"
                    Grid.Column="2"
                    Content="Historial  ◴"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonHistory_Click"/>

                        <Button x:Name="ButtonScoreboard"
                    Grid.Column="3"
                    Content="Marcadores  🏆"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonScoreboard_Click"/>

                        <Button x:Name="ButtonSettings"
                    Grid.Column="4"
                    Content="Ajustes  ⚙"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonSettings_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>