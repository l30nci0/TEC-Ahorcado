<Page x:Class="LetterClashClient.Views.GUIProfileView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUIProfileView"
      Loaded="Page_Loaded"
      Background="#0B0E14">

    <Page.Resources>
        <!-- Modern Dark Grayscale TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="BorderBrush" Value="#00A896"/>
            <Setter Property="Foreground" Value="#00A896"/>
            <Setter Property="CaretBrush" Value="#00A896"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.5"/>   
                            </Border.Effect>
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#00A896"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#00A896" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#4DEEEA" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="true">
                                <Setter Property="Background" Value="#181E29"/>
                                <Setter Property="BorderBrush" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#7DE2D1"/>
                            </Trigger>
                            
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Dark Grayscale PasswordBox Style -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="BorderBrush" Value="#00A896"/>
            <Setter Property="Foreground" Value="#00A896"/>
            <Setter Property="CaretBrush" Value="#00A896"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="neonGlow" BlurRadius="12" Color="#00A896" Opacity="0.5" ShadowDepth="0"/>
                                </Border.Effect>
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#4DEEEA" Opacity="0.7"/>
                                </Setter.Value>
                            </Setter>
                              </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#4DEEEA" Opacity="0.7"/>
                                </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom DatePicker Template & Style -->
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid x:Name="PART_Root" HorizontalAlignment="{TemplateBinding HorizontalAlignment}" VerticalAlignment="{TemplateBinding VerticalAlignment}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               Focusable="{TemplateBinding Focusable}"
                                               HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                               VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                               Background="#0B0E14"
                                               Foreground="#4DEEEA"
                                               BorderThickness="1.5,1.5,0,1.5"
                                               BorderBrush="#00A896"
                                               Padding="10,6"
                                               FontFamily="{StaticResource GeistMono}"
                                               FontSize="13"/>
                                               
                            <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    Width="36"
                                    Focusable="False"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="btnBorder"
                                                Background="#061A22"
                                                BorderBrush="#00FFCC"
                                                BorderThickness="1,1.5,1.5,1.5"
                                                CornerRadius="0">
                                            <TextBlock x:Name="btnIcon"
                                                       Text="📅" 
                                                       Foreground="#4DEEEA"
                                                       FontSize="13"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                
                                                <Setter TargetName="btnBorder" Property="Background" Value="#00FFCC"/>
                                                <Setter TargetName="btnIcon" Property="Foreground" Value="#050D14"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="btnBorder" Property="Background" Value="#99FFE8"/>
                                                <Setter TargetName="btnIcon" Property="Foreground" Value="#050D14"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#050D14"
                                        BorderBrush="#00FFCC"
                                        BorderThickness="1.5"
                                        Padding="5"
                                        CornerRadius="0">
                                    <Calendar x:Name="PART_Calendar"
                                              Background="#050D14"
                                              Foreground="#00FFCC"
                                              BorderThickness="0"/>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Retro Grayscale Primary Button Style -->
        <Style x:Key="ModernPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#00FFCC"/>
            <Setter Property="Foreground" Value="#050D14"/>
            <Setter Property="BorderBrush" Value="#00FFCC"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00FFCC" Opacity="0.6"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                               <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                               <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                               <Setter Property="Foreground" Value="#050D14"/>

                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00A896"/>
                                <Setter Property="Foreground" Value="#050D14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#061A22"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#061A22"/>
                                <Setter Property="Foreground" Value="#1A3D35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Retro Grayscale Secondary Button Style -->
        <Style x:Key="ModernSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#F649A7"/>
            <Setter Property="BorderBrush" Value="#E60067"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#9B004F" Opacity="0.6"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#F649A7"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F649A7"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#E60067"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E60067"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#061A22"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0A1F2A"/>
                                <Setter Property="Foreground" Value="#1A3D35"/>
                                <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="0" ShadowDepth="0" Color="#000000" Opacity="0"/>
                                </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Bottom Navigation Bar Buttons -->
        <Style x:Key="NavBarButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Foreground" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Foreground" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#4A5568"/>
                                <Setter TargetName="border" Property="Background" Value="#181E29"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0A1F2A"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form Elements Generic Styles -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00A896"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#00A896"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PlaceholderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#00A896"/>
            <Setter Property="Margin" Value="14,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <Style x:Key="ErrorLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#E60067"/>
            <Setter Property="Margin" Value="2,2,0,8"/>
            <Setter Property="Visibility" Value="Hidden"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Modern Grid Line Background -->
        <Grid.Background>
            <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                <DrawingBrush.Drawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#050D14" Thickness="1"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,0" EndPoint="40,0"/>
                                <LineGeometry StartPoint="0,0" EndPoint="0,40"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </Grid.Background>

        <!-- Main Shell Grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80" x:Name="RowFooter"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Content Area containing Card -->
            <Grid Grid.Row="0">
                <!-- Main Card Container -->
                <Border Width="950"
                        Height="530"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        BorderBrush="#4DEEEA"
                        BorderThickness="1.5"
                        Background="#0B0E14"
                        CornerRadius="0"
                        Padding="30">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
                    </Border.Effect>

                    <Grid>
                        <!-- ================= VIEW MODE ================= -->
                        <Grid x:Name="GridProfileView" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- View Mode Header -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="{DynamicResource Profile_Title}"
                                           FontFamily="{StaticResource GeistPixelSquare}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#4DEEEA"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>

                                <TextBlock x:Name="TextBlockUsernameHeader"
                                           Text="&quot;NOMBRE DE USUARIO&quot;"
                                           FontFamily="{StaticResource GeistMono}"
                                           FontSize="13"
                                           Foreground="#4DEEEA"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- View Mode Content (Vertical Stack) -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Width="500" VerticalAlignment="Center" Margin="0,10,0,15">
                                    <!-- Full Name -->
                                    <TextBlock Text="{DynamicResource Profile_FullNameLabel}" Style="{StaticResource FormLabelStyle}"/>
                                    <Border BorderBrush="#4DEEEA" BorderThickness="1" Background="#0B0E14" Padding="15,10" Margin="0,0,0,15">
                                        <TextBlock x:Name="TextBlockFullName" Style="{StaticResource ValueTextStyle}"/>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#00A896" Opacity="0.4"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Email -->
                                    <TextBlock Text="{DynamicResource Profile_EmailLabel}" Style="{StaticResource FormLabelStyle}"/>
                                    <Border BorderBrush="#4DEEEA" BorderThickness="1" Background="#0B0E14" Padding="15,10" Margin="0,0,0,15">
                                        <TextBlock x:Name="TextBlockEmail" Style="{StaticResource ValueTextStyle}"/>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#00A896" Opacity="0.4"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Phone -->
                                    <TextBlock Text="{DynamicResource Profile_PhoneLabel}" Style="{StaticResource FormLabelStyle}"/>
                                    <Border BorderBrush="#4DEEEA" BorderThickness="1" Background="#0B0E14" Padding="15,10" Margin="0,0,0,15">
                                        <TextBlock x:Name="TextBlockPhone" Style="{StaticResource ValueTextStyle}"/>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#00A896" Opacity="0.4"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Birthday and Age Row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="1.5*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{DynamicResource Profile_AgeLabel}" Style="{StaticResource FormLabelStyle}"/>
                                            <Border BorderBrush="#4DEEEA" BorderThickness="1" Background="#0B0E14" Padding="15,10">
                                                <TextBlock x:Name="TextBlockAge" Style="{StaticResource ValueTextStyle}"/>
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#00A896" Opacity="0.4"/>
                                                </Border.Effect>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{DynamicResource Profile_BirthDateLabel}" Style="{StaticResource FormLabelStyle}"/>
                                            <Border BorderBrush="#4DEEEA" BorderThickness="1" Background="#0B0E14" Padding="15,10">
                                                <TextBlock x:Name="TextBlockBirthDate" Style="{StaticResource ValueTextStyle}"/>
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#00A896" Opacity="0.4"/>
                                                </Border.Effect>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <!-- Action Button at bottom -->
                                <Button x:Name="ButtonEdit"
                                        Grid.Row="1"
                                        Content="{DynamicResource Profile_BtnEdit}"
                                        Height="45"
                                        Width="250"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource ModernPrimaryButton}"
                                        Click="ButtonEdit_Click"
                                        BorderThickness="1.5"/>
                            </Grid>
                        </Grid>

                        <!-- ================= EDIT MODE ================= -->
                        <Grid x:Name="GridProfileEdit" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Edit Mode Header -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                                <TextBlock Text="{DynamicResource Profile_EditTitle}"
                                           FontFamily="{StaticResource GeistPixelSquare}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#4DEEEA"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4"
                                           >
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="10" 
                                        ShadowDepth="0" Color="#00A896" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            <TextBlock Text="{DynamicResource Profile_EditSubtitle}"
                                           FontFamily="{StaticResource GeistMono}"
                                           FontSize="12"
                                           Foreground="#00A896"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>                            <!-- Edit Mode Fields (Horizontal Grid Layout) -->
                            <!-- Edit Mode Fields Grid -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="20"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Two Columns (General & Personal Info) -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Column (Account Settings) -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <!-- Username read-only field -->
                                        <TextBlock Text="{DynamicResource Profile_UsernameEditLabel}" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox x:Name="TextBoxUsername" Height="36" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Margin="0,0,0,18" Background="#0B0E14" BorderBrush="#00A986"/>

                                        <!-- Segmented Language Selection -->
                                        <TextBlock Text="{DynamicResource Profile_PreferredLanguageLabel}" Style="{StaticResource FormLabelStyle}"/>
                                        <Grid Height="36">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="ButtonLangES" Grid.Column="0" Content="ESPAÑOL" Style="{StaticResource ModernPrimaryButton}" Margin="0,0,4,0" Click="ButtonLangES_Click"/>
                                            <Button x:Name="ButtonLangEN" Grid.Column="1" Content="ENGLISH" Style="{StaticResource ModernSecondaryButton}" Margin="4,0,0,0" Click="ButtonLangEN_Click"/>
                                        </Grid>
                                        <TextBlock x:Name="TextBlockLanguageError" Text="{DynamicResource Profile_LanguageError}" Style="{StaticResource ErrorLabelStyle}" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Divider -->
                                    <Border Grid.Column="1" Width="1.5" Background="#4DEEEA" VerticalAlignment="Stretch" Margin="0,5">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#4DEEEA" Opacity="0.5"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Right Column (Personal Information) -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Stretch">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Full Name -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{DynamicResource Profile_FullNameLabel}" Style="{StaticResource FormLabelStyle}"/>
                                                <TextBox x:Name="TextBoxFullName" Height="36" Style="{StaticResource ModernTextBox}"/>
                                                <TextBlock x:Name="TextBlockFullNameError" Text="{DynamicResource Profile_FullNameError}" Style="{StaticResource ErrorLabelStyle}"/>
                                            </StackPanel>

                                            <!-- Birthday -->
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{DynamicResource Profile_BirthdayLabel}" Style="{StaticResource FormLabelStyle}"/>
                                                <DatePicker x:Name="DatePickerBirthDate" Height="36" Style="{StaticResource ModernDatePicker}" HorizontalAlignment="Stretch"/>
                                                <TextBlock x:Name="TextBlockBirthDateError" Text="{DynamicResource Profile_BirthDateError}" Style="{StaticResource ErrorLabelStyle}"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,-4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.3*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Email read-only -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{DynamicResource Profile_EmailLabel}" Style="{StaticResource FormLabelStyle}"/>
                                                <TextBox x:Name="TextBoxEmail" Height="36" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Background="#0B0E14" BorderBrush="#00A986"/>
                                            </StackPanel>

                                            <!-- Phone -->
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{DynamicResource Profile_PhoneLabel}" Style="{StaticResource FormLabelStyle}"/>
                                                <TextBox x:Name="TextBoxPhone" Height="36" Style="{StaticResource ModernTextBox}"/>
                                                <TextBlock x:Name="TextBlockPhoneError" Text="{DynamicResource Profile_PhoneError}" Style="{StaticResource ErrorLabelStyle}"></TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 2: Change Password Section (Horizontal 3-column Layout) -->
                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="{DynamicResource Profile_ChangePasswordHeader}" Style="{StaticResource FormLabelStyle}" Foreground="#4DEEEA" Margin="0,0,0,10"/>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Current Password -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{DynamicResource Profile_CurrentPasswordLabel}" Style="{StaticResource FormLabelStyle}"/>
                                            <Grid Height="36">
                                                <PasswordBox x:Name="PasswordBoxCurrentPassword" Style="{StaticResource ModernPasswordBox}" PasswordChanged="PasswordBoxCurrentPassword_PasswordChanged"/>
                                                <TextBlock x:Name="TextBlockCurrentPasswordPlaceholder" Text="{DynamicResource Profile_CurrentPasswordPlaceholder}" Style="{StaticResource PlaceholderStyle}"/>
                                            </Grid>
                                            <TextBlock x:Name="TextBlockCurrentPasswordError" Text="{DynamicResource Profile_CurrentPasswordError}" Style="{StaticResource ErrorLabelStyle}"/>
                                        </StackPanel>

                                        <!-- New Password -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{DynamicResource Profile_NewPasswordLabel}" Style="{StaticResource FormLabelStyle}"/>
                                            <Grid Height="36">
                                                <PasswordBox x:Name="PasswordBoxPassword" Style="{StaticResource ModernPasswordBox}" PasswordChanged="PasswordBoxPassword_PasswordChanged"/>
                                                <TextBlock x:Name="TextBlockPasswordPlaceholder" Text="{DynamicResource Profile_NewPasswordPlaceholder}" Style="{StaticResource PlaceholderStyle}"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Confirm Password -->
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="{DynamicResource Profile_ConfirmNewPasswordLabel}" Style="{StaticResource FormLabelStyle}"/>
                                            <Grid Height="36">
                                                <PasswordBox x:Name="PasswordBoxConfirmPassword" Style="{StaticResource ModernPasswordBox}" PasswordChanged="PasswordBoxConfirmPassword_PasswordChanged"/>
                                                <TextBlock x:Name="TextBlockConfirmPasswordPlaceholder" Text="{DynamicResource Profile_ConfirmNewPasswordPlaceholder}" Style="{StaticResource PlaceholderStyle}"/>
                                            </Grid>
                                            <TextBlock x:Name="TextBlockPasswordError" Text="{DynamicResource Profile_PasswordMatchError}" Style="{StaticResource ErrorLabelStyle}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 1: Footer containing Navigation OR Edit Buttons -->
            <!-- 1. VIEW MODE FOOTER -->
            <Border x:Name="GridFooterNavigation"
                    Grid.Row="1"
                    BorderBrush="#00A896"
                    BorderThickness="0,1,0,0"
                    Background="#0B0E14"
                    Visibility="Visible">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ButtonMainMenu"
                                                            Grid.Column="0"
                                                            Content="{DynamicResource Nav_MainMenu}"
                                                            Style="{StaticResource NavBarButton}"
                                                            Click="ButtonMainMenu_Click"/>

                                                    <Button x:Name="ButtonProfile"
                                                            Grid.Column="1"
                                                            Content="{DynamicResource Nav_Profile}"
                                                            Style="{StaticResource NavBarButton}"
                                                            Click="ButtonProfile_Click"/>

                                                    <Button x:Name="ButtonHistory"
                                                            Grid.Column="2"
                                                            Content="{DynamicResource Nav_History}"
                                                            Style="{StaticResource NavBarButton}"
                                                            Click="ButtonHistory_Click"/>

                                                    <Button x:Name="ButtonScoreboard"
                                                            Grid.Column="3"
                                                            Content="{DynamicResource Nav_Scoreboard}"
                                                            Style="{StaticResource NavBarButton}"
                                                            Click="ButtonScoreboard_Click"/>

                                                    <Button x:Name="ButtonSettings"
                                                            Grid.Column="4"
                                                            Content="{DynamicResource Nav_Settings}"
                                                            Style="{StaticResource NavBarButton}"
                                                            Click="ButtonSettings_Click"/>
                </Grid>
            </Border>

            <!-- 2. EDIT MODE FOOTER -->
            <Border x:Name="GridFooterEdit"
                    Grid.Row="1"
                    BorderBrush="#00A896"
                    BorderThickness="0,1,0,0"
                    Background="#0B0E14"
                    Visibility="Collapsed">
                <Grid Width="500" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ButtonSave"
                            Grid.Column="0"
                            Content="{DynamicResource Profile_BtnSave}"
                            Height="45"
                            Style="{StaticResource ModernPrimaryButton}"
                            VerticalAlignment="Center"
                            Click="ButtonSave_Click"/>

                    <Button x:Name="ButtonCancel"
                            Grid.Column="2"
                            Content="{DynamicResource Profile_BtnCancel}"
                            Height="45"
                            Style="{StaticResource ModernSecondaryButton}"
                            VerticalAlignment="Center"
                            Click="ButtonCancel_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Hidden elements to preserve code-behind field references -->
        <Grid Visibility="Collapsed">
            <ComboBox x:Name="ComboBoxPreferredLanguage">
                <ComboBoxItem Content="Seleccione Idioma"/>
                <ComboBoxItem Content="Ingles"/>
                <ComboBoxItem Content="Español"/>
            </ComboBox>
            <Image x:Name="ImageLogo"/>
            <Canvas x:Name="CanvasHangmanProfile"/>
            <Image x:Name="ImageHangman"/>
            <Border x:Name="BorderUserAvatar"/>
        </Grid>
    </Grid>
</Page>
