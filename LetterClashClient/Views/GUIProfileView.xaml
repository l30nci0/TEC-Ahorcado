<Page x:Class="LetterClashClient.Views.GUIProfileView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUIProfileView"
      Loaded="Page_Loaded"
      Background="#0B0E14">

    <Page.Resources>
        <!-- Modern Dark Grayscale TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
      <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="BorderBrush" Value="#181E29"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="CaretBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0"/>   
                            </Border.Effect>
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity         ="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="true">
                                <Setter Property="Background" Value="#09090B"/>
                                <Setter Property="BorderBrush" Value="#181E29"/>
                                <Setter Property="Foreground" Value="#7DE2D1"/>
                            </Trigger>
                            
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Dark Grayscale PasswordBox Style -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#09090B"/>
            <Setter Property="BorderBrush" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="CaretBrush" Value="#F4F4F5"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3F3F46"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#E4E4E7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom DatePicker Template & Style -->
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid x:Name="PART_Root" HorizontalAlignment="{TemplateBinding HorizontalAlignment}" VerticalAlignment="{TemplateBinding VerticalAlignment}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               Focusable="{TemplateBinding Focusable}"
                                               HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                               VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                               Background="#09090B"
                                               Foreground="#F4F4F5"
                                               BorderThickness="1.5,1.5,0,1.5"
                                               BorderBrush="#2D2D30"
                                               Padding="10,6"
                                               FontFamily="{StaticResource GeistMono}"
                                               FontSize="13"/>
                                               
                            <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    Width="36"
                                    Focusable="False"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="btnBorder"
                                                Background="#18181B"
                                                BorderBrush="#2D2D30"
                                                BorderThickness="1,1.5,1.5,1.5"
                                                CornerRadius="0">
                                            <TextBlock Text="📅" 
                                                       Foreground="#A1A1AA"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btnBorder" Property="BorderBrush" Value="#E4E4E7"/>
                                                <Setter TargetName="btnBorder" Property="Background" Value="#27272A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#121214"
                                        BorderBrush="#2D2D30"
                                        BorderThickness="1.5"
                                        Padding="5"
                                        CornerRadius="0">
                                    <Calendar x:Name="PART_Calendar"
                                              Background="#121214"
                                              Foreground="#F4F4F5"
                                              BorderThickness="0"/>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Retro Grayscale Primary Button Style -->
        <Style x:Key="ModernPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#4DEEEA" Opacity="0.6"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                                

                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00A896"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#27272A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#71717A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Retro Grayscale Secondary Button Style -->
        <Style x:Key="ModernSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#F649A7"/>
            <Setter Property="BorderBrush" Value="#E60067"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#27272A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F4F4F5"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#09090B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="BorderBrush" Value="#09090B"/>
                                <Setter Property="Foreground" Value="#52525B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Bottom Navigation Bar Buttons -->
        <Style x:Key="NavBarButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Foreground" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Foreground" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#4A5568"/>
                                <Setter TargetName="border" Property="Background" Value="#181E29"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form Elements Generic Styles -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00A896"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#00A896"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PlaceholderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#4A5263"/>
            <Setter Property="Margin" Value="14,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <Style x:Key="ErrorLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#E60067"/>
            <Setter Property="Margin" Value="2,2,0,8"/>
            <Setter Property="Visibility" Value="Hidden"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Modern Grid Line Background -->
        <Grid.Background>
            <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                <DrawingBrush.Drawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#15151A" Thickness="1"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,0" EndPoint="40,0"/>
                                <LineGeometry StartPoint="0,0" EndPoint="0,40"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </Grid.Background>

        <!-- Main Shell Grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80" x:Name="RowFooter"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Content Area containing Card -->
            <Grid Grid.Row="0">
                <!-- Main Card Container -->
                <Border Width="950"
                        Height="530"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        BorderBrush="#4DEEEA"
                        BorderThickness="1.5"
                        Background="#0B0E14"
                        CornerRadius="0"
                        Padding="30">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
                    </Border.Effect>

                    <Grid>
                        <!-- ================= VIEW MODE ================= -->
                        <Grid x:Name="GridProfileView" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- View Mode Header -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="PERFIL"
                                           FontFamily="{StaticResource GeistPixelSquare}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#4DEEEA"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>

                                <TextBlock x:Name="TextBlockUsernameHeader"
                                           Text="&quot;NOMBRE DE USUARIO&quot;"
                                           FontFamily="{StaticResource GeistMono}"
                                           FontSize="13"
                                           Foreground="#4DEEEA"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- View Mode Content Columns -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="0.8*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left column (Fields) -->
                                <StackPanel Grid.Column="0" Margin="0,0,30,0" VerticalAlignment="Center">
                                    <!-- Full Name -->
                                    <TextBlock Text="NOMBRE COMPLETO" Style="{StaticResource FormLabelStyle}"/>
                                    <Border BorderBrush="#4DEEEA" BorderThickness="1" Background="#0B0E14" Padding="15,10" Margin="0,0,0,15">
                                        <TextBlock x:Name="TextBlockFullName" Style="{StaticResource ValueTextStyle}"/>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.5"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Birthday and Age Row -->
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="1.5*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="EDAD" Style="{StaticResource FormLabelStyle}"/>
                                            <Border BorderBrush="#4DEEEA" BorderThickness="1" Background="#0B0E14" Padding="15,10">
                                                <TextBlock x:Name="TextBlockAge" Style="{StaticResource ValueTextStyle}"/>
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.5"/>
                                                </Border.Effect>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="FECHA DE NACIMIENTO" Style="{StaticResource FormLabelStyle}"/>
                                            <Border BorderBrush="#4DEEEA" BorderThickness="1" Background="#0B0E14" Padding="15,10">
                                                <TextBlock x:Name="TextBlockBirthDate" Style="{StaticResource ValueTextStyle}"/>
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.5"/>
                                                </Border.Effect>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Email -->
                                    <TextBlock Text="CORREO ELECTRÓNICO" Style="{StaticResource FormLabelStyle}"/>
                                    <Border BorderBrush="#4DEEEA" BorderThickness="1" Background="#0B0E14" Padding="15,10" Margin="0,0,0,15">
                                        <TextBlock x:Name="TextBlockEmail" Style="{StaticResource ValueTextStyle}"/>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.5"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- Phone -->
                                    <TextBlock Text="TELÉFONO" Style="{StaticResource FormLabelStyle}"/>
                                    <Border BorderBrush="#4DEEEA" BorderThickness="1" Background="#0B0E14" Padding="15,10">
                                        <TextBlock x:Name="TextBlockPhone" Style="{StaticResource ValueTextStyle}"/>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.5"/>
                                        </Border.Effect>
                                    </Border>
                                </StackPanel>

                                <!-- Divider -->
                <Border Grid.Column="1" Width="1.5" Background="#4DEEEA" VerticalAlignment="Stretch" Margin="0,5">
                  <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#4DEEEA" Opacity="0.6"/>
                  </Border.Effect>
                </Border>

                <!-- Right Column (Avatar & Action) -->
                                <Grid Grid.Column="2" Margin="30,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="AVATAR DE JUGADOR" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                        <Border Width="150" Height="150" BorderBrush="#4DEEEA" BorderThickness="1.5" Background="#0B0E14">
                                            <Image x:Name="ImageUserAvatar" Source="/Assets/Images/UserAvatar.png" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
                                            </Border.Effect>
                                        </Border>
                                    </StackPanel>

                  <Button x:Name="ButtonEdit"
                                            Grid.Row="1"
                                            Content="EDITAR PERFIL  🛠"
                                            Height="50"
                                            Style="{StaticResource ModernPrimaryButton}"
                                            Click="ButtonEdit_Click"
                                            BorderThickness="1.5"/>
                                </Grid>
                            </Grid>
                        </Grid>

                        <!-- ================= EDIT MODE ================= -->
                        <Grid x:Name="GridProfileEdit" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Edit Mode Header -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                                <TextBlock Text="EDITAR PERFIL"
                                           FontFamily="{StaticResource GeistPixelSquare}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#4DEEEA"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4"
                                           >
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="10" 
                                        ShadowDepth="0" Color="#00A896" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            <TextBlock Text="Modifica los datos personales de tu cuenta"
                                           FontFamily="{StaticResource GeistMono}"
                                           FontSize="12"
                                           Foreground="#7DE2D1"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Edit Mode Fields Grid -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <!-- Left Edit Panel (Avatar / Language / Account) -->
                                    <ColumnDefinition Width="1.1*"/>
                                    <!-- Divider -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Right Edit Panel (Form fields) -->
                                    <ColumnDefinition Width="1.4*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left Column -->
                                <StackPanel Grid.Column="0" Margin="0,0,25,0" VerticalAlignment="Center">
                                    <TextBlock Text="AVATAR DE PERFIL" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <Grid Width="130" Height="130" Margin="0,0,0,15" HorizontalAlignment="Center">
                                        <Border BorderBrush="#4DEEEA" BorderThickness="1.5" Background="#0B0E14">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
                                        </Border.Effect>
                                        <Image x:Name="ImageEditUserAvatar" Source="/Assets/Images/UserAvatar.png" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Button x:Name="ButtonAddAvatar" Content="+" Width="36" Height="36" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="Hand" Click="ButtonAddAvatar_Click" Style="{StaticResource ModernPrimaryButton}"/>
                                    </Grid>

                                    <!-- Username read-only field -->
                                    <TextBlock Text="NOMBRE DE JUGADOR" Style="{StaticResource FormLabelStyle}"/>
                                    <TextBox x:Name="TextBoxUsername" Height="38" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Margin="0,0,0,15"/>

                                    <!-- Segmented Language Selection -->
                                    <TextBlock Text="IDIOMA PREFERIDO" Style="{StaticResource FormLabelStyle}"/>
                                    <Grid Height="38">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="ButtonLangES" Grid.Column="0" Content="ESPAÑOL" Style="{StaticResource ModernPrimaryButton}" Margin="0,0,4,0" Click="ButtonLangES_Click"/>
                                        <Button x:Name="ButtonLangEN" Grid.Column="1" Content="ENGLISH" Style="{StaticResource ModernSecondaryButton}" Margin="4,0,0,0" Click="ButtonLangEN_Click"/>
                                    </Grid>
                                    <TextBlock x:Name="TextBlockLanguageError" Text="Seleccione un idioma" Style="{StaticResource ErrorLabelStyle}"/>
                                </StackPanel>

                                <!-- Divider -->
                                <Border Grid.Column="1" Width="1.5" Background="#4DEEEA" VerticalAlignment="Stretch" Margin="0,5"/>

                                <!-- Right Column -->
                                <ScrollViewer Grid.Column="2" Margin="25,0,0,0" VerticalScrollBarVisibility="Auto" Focusable="False">
                                    <StackPanel VerticalAlignment="Center">
                                        <!-- Full Name -->
                                        <TextBlock Text="NOMBRE COMPLETO" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox x:Name="TextBoxFullName" Height="38" Style="{StaticResource ModernTextBox}"/>
                                        <TextBlock x:Name="TextBlockFullNameError" Text="Ingrese un nombre válido" Style="{StaticResource ErrorLabelStyle}"/>

                                        <!-- Email read-only -->
                                        <TextBlock Text="CORREO ELECTRÓNICO" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox x:Name="TextBoxEmail" Height="38" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Margin="0,0,0,12"/>

                                        <!-- Phone -->
                                        <TextBlock Text="TELÉFONO" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox x:Name="TextBoxPhone" Height="38" Style="{StaticResource ModernTextBox}"/>
                                        <TextBlock x:Name="TextBlockPhoneError" Text="Coloque solo números (10 dígitos)" Style="{StaticResource ErrorLabelStyle}"/>

                                        <!-- Birthday -->
                                        <TextBlock Text="CUMPLEAÑOS" Style="{StaticResource FormLabelStyle}"/>
                                        <DatePicker x:Name="DatePickerBirthDate" Height="38" Style="{StaticResource ModernDatePicker}" HorizontalAlignment="Stretch"/>
                                        <TextBlock x:Name="TextBlockBirthDateError" Text="Seleccione una fecha" Style="{StaticResource ErrorLabelStyle}"/>

                                        <!-- Passwords Grid -->
                                        <TextBlock Text="CAMBIAR CONTRASEÑA" Style="{StaticResource FormLabelStyle}" Foreground="#7DE2D1" Margin="0,10,0,5"/>

                                        <!-- Current Password -->
                                        <TextBlock Text="CONTRASEÑA ACTUAL" Style="{StaticResource FormLabelStyle}"/>
                                        <Grid Height="38">
                                            <PasswordBox x:Name="PasswordBoxCurrentPassword" Style="{StaticResource ModernPasswordBox}" PasswordChanged="PasswordBoxCurrentPassword_PasswordChanged"/>
                                            <TextBlock x:Name="TextBlockCurrentPasswordPlaceholder" Text="Requerida para cambiar contraseña" Style="{StaticResource PlaceholderStyle}"/>
                                        </Grid>
                                        <TextBlock x:Name="TextBlockCurrentPasswordError" Text="Contraseña actual incorrecta" Style="{StaticResource ErrorLabelStyle}"/>

                                        <!-- New Password -->
                                        <TextBlock Text="NUEVA CONTRASEÑA" Style="{StaticResource FormLabelStyle}"/>
                                        <Grid Height="38" Margin="0,0,0,12">
                                            <PasswordBox x:Name="PasswordBoxPassword" Style="{StaticResource ModernPasswordBox}" PasswordChanged="PasswordBoxPassword_PasswordChanged"/>
                                            <TextBlock x:Name="TextBlockPasswordPlaceholder" Text="Dejar vacío si no desea cambiarla" Style="{StaticResource PlaceholderStyle}"/>
                                        </Grid>

                                        <!-- Confirm Password -->
                                        <TextBlock Text="CONFIRMAR CONTRASEÑA" Style="{StaticResource FormLabelStyle}"/>
                                        <Grid Height="38">
                                            <PasswordBox x:Name="PasswordBoxConfirmPassword" Style="{StaticResource ModernPasswordBox}" PasswordChanged="PasswordBoxConfirmPassword_PasswordChanged"/>
                                            <TextBlock x:Name="TextBlockConfirmPasswordPlaceholder" Text="Confirme nueva contraseña" Style="{StaticResource PlaceholderStyle}"/>
                                        </Grid>
                                        <TextBlock x:Name="TextBlockPasswordError" Text="Contraseña es diferente" Style="{StaticResource ErrorLabelStyle}"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 1: Footer containing Navigation OR Edit Buttons -->
            <!-- 1. VIEW MODE FOOTER -->
            <Border x:Name="GridFooterNavigation"
                    Grid.Row="1"
                    BorderBrush="#2D2D30"
                    BorderThickness="0,1,0,0"
                    Background="#121214"
                    Visibility="Visible">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ButtonMainMenu"
                            Grid.Column="0"
                            Content="Menu Principal  ⚔"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonMainMenu_Click"/>

                    <Button x:Name="ButtonProfile"
                            Grid.Column="1"
                            Content="Perfil  👤"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonProfile_Click"/>

                    <Button x:Name="ButtonHistory"
                            Grid.Column="2"
                            Content="Historial  ◴"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonHistory_Click"/>

                    <Button x:Name="ButtonScoreboard"
                            Grid.Column="3"
                            Content="Marcadores  🏆"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonScoreboard_Click"/>

                    <Button x:Name="ButtonSettings"
                            Grid.Column="4"
                            Content="Ajustes  ⚙"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonSettings_Click"/>
                </Grid>
            </Border>

            <!-- 2. EDIT MODE FOOTER -->
            <Border x:Name="GridFooterEdit"
                    Grid.Row="1"
                    BorderBrush="#2D2D30"
                    BorderThickness="0,1,0,0"
                    Background="#121214"
                    Visibility="Collapsed">
                <Grid Width="500" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ButtonSave"
                            Grid.Column="0"
                            Content="Guardar Cambios  ✓"
                            Height="45"
                            Style="{StaticResource ModernPrimaryButton}"
                            VerticalAlignment="Center"
                            Click="ButtonSave_Click"/>

                    <Button x:Name="ButtonCancel"
                            Grid.Column="2"
                            Content="Cancelar  ✕"
                            Height="45"
                            Style="{StaticResource ModernSecondaryButton}"
                            VerticalAlignment="Center"
                            Click="ButtonCancel_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Hidden elements to preserve code-behind field references -->
        <Grid Visibility="Collapsed">
            <ComboBox x:Name="ComboBoxPreferredLanguage">
                <ComboBoxItem Content="Seleccione Idioma"/>
                <ComboBoxItem Content="Ingles"/>
                <ComboBoxItem Content="Español"/>
            </ComboBox>
            <Image x:Name="ImageLogo"/>
            <Canvas x:Name="CanvasHangmanProfile"/>
            <Image x:Name="ImageHangman"/>
            <Border x:Name="BorderUserAvatar"/>
        </Grid>
    </Grid>
</Page>
