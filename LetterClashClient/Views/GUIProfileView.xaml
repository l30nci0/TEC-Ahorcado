<Page x:Class="LetterClashClient.Views.GUIProfileView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUIProfileView"
      Loaded="Page_Loaded">

    <Grid Background="#F4F4F4">
        <Border Margin="20"
            BorderBrush="#2B2B2B"
            BorderThickness="2"
            Background="White">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80" x:Name="RowFooter"/>
                </Grid.RowDefinitions>

                <!-- 1. VIEW MODE GRID -->
                <Grid x:Name="GridProfileView" Grid.Row="0" Margin="25" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52*"/>
                        <ColumnDefinition Width="48*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Width="260"
                                Height="55"
                                BorderBrush="#2B2B2B"
                                BorderThickness="1"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <Grid>
                                <TextBlock x:Name="TextBlockUsernameHeader"
                                           Text="&quot;NOMBRE DE USUARIO&quot;"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#111111"
                                           VerticalAlignment="Center"
                                           Margin="15,0,0,0"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Width="560"
                                Height="330"
                                BorderBrush="#2B2B2B"
                                BorderThickness="1"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="0,15,0,0">
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Nombre:" FontSize="17" Foreground="#111111" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TextBlockFullName" Grid.Column="1" FontSize="17" Foreground="#111111" VerticalAlignment="Center" TextDecorations="Underline"/>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Edad:" FontSize="17" Foreground="#111111" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TextBlockAge" Grid.Column="1" FontSize="17" Foreground="#111111" VerticalAlignment="Center" TextDecorations="Underline"/>
                                    <TextBlock Grid.Column="2" Text="Cumple:" FontSize="17" Foreground="#111111" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TextBlockBirthDate" Grid.Column="3" FontSize="17" Foreground="#111111" VerticalAlignment="Center" TextDecorations="Underline"/>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="145"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Correo Electrónico:" FontSize="17" Foreground="#111111" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TextBlockEmail" Grid.Column="1" FontSize="17" Foreground="#111111" VerticalAlignment="Center" TextDecorations="Underline"/>
                                </Grid>

                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Teléfono:" FontSize="17" Foreground="#111111" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TextBlockPhone" Grid.Column="1" FontSize="17" Foreground="#111111" VerticalAlignment="Center" TextDecorations="Underline"/>
                                </Grid>

                                <Button x:Name="ButtonEdit"
                                        Grid.Row="4"
                                        Content="Editar  🛠"
                                        Width="160"
                                        Height="38"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Cursor="Hand"
                                        Click="ButtonEdit_Click"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="110"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Image x:Name="ImageLogo"
                               Grid.Row="0"
                               Source="/Assets/Images/LogoLetterClash.jpeg"
                               Width="320"
                               Height="95"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                        <Canvas x:Name="CanvasHangmanProfile"
                                Grid.Row="1"
                                Width="320"
                                Height="350"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,15,0,0">
                            <Image x:Name="ImageHangman"
                                   Source="/Assets/Images/Hangedman5.jpg"
                                   Width="280"
                                   Height="310"
                                   Stretch="Uniform"
                                   Canvas.Left="20"
                                   Canvas.Top="15"/>
                            <Border x:Name="BorderUserAvatar"
                                    Width="72"
                                    Height="72"
                                    CornerRadius="36"
                                    BorderBrush="#2B2B2B"
                                    BorderThickness="2"
                                    Background="White"
                                    Canvas.Left="192"
                                    Canvas.Top="80">
                                <Image x:Name="ImageUserAvatar"
                                       Source="/Assets/Images/UserAvatar.png"
                                       Width="58"
                                       Height="58"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>
                        </Canvas>
                    </Grid>
                </Grid>

                <!-- 2. EDIT MODE GRID -->
                <Grid x:Name="GridProfileEdit" Grid.Row="0" Margin="25" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42*"/>
                        <ColumnDefinition Width="58*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Edit Panel -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="85"/>
                            <RowDefinition Height="175"/>
                            <RowDefinition Height="90"/>
                            <RowDefinition Height="110"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="45,0,0,0">
                            <TextBlock Text="E D I T A R..." FontSize="36" FontWeight="SemiBold" Foreground="#1E1E2F" VerticalAlignment="Center"/>
                            <TextBlock Text=" 🛠" FontSize="30" FontWeight="SemiBold" Foreground="#1E1E2F" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Rectangle Grid.Row="0" Height="3" Width="300" Fill="#1E1E2F" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="45,0,0,5"/>

                        <Grid Grid.Row="1" HorizontalAlignment="Left" Margin="115,0,0,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top">
                                <TextBlock Text="Avatar" FontSize="18" Foreground="#222222" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <Grid Width="145" Height="145">
                                    <Image x:Name="ImageEditUserAvatar" Source="/Assets/Images/UserAvatar.png" Width="135" Height="135" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Button x:Name="ButtonAddAvatar" Content="+" Width="38" Height="38" FontSize="26" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="Hand" Click="ButtonAddAvatar_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="White" BorderBrush="#2B2B2B" BorderThickness="2" CornerRadius="19">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2" Width="430" HorizontalAlignment="Left" Margin="15,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="35"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Nombre de Jugador" FontSize="15" Foreground="#222222"/>
                            <TextBox x:Name="TextBoxUsername" Grid.Row="1" Height="35" FontSize="15" Padding="8,4" IsReadOnly="True" Background="#EDEDED"/>
                        </Grid>

                        <Grid Grid.Row="3" Width="430" HorizontalAlignment="Left" Margin="75,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="210"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="25"/>
                                    <RowDefinition Height="38"/>
                                    <RowDefinition Height="35"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Idioma Preferido" FontSize="15" Foreground="#222222"/>
                                <ComboBox x:Name="ComboBoxPreferredLanguage" Grid.Row="1" Height="35" FontSize="15" SelectedIndex="2">
                                    <ComboBoxItem Content="Seleccione Idioma"/>
                                    <ComboBoxItem Content="Ingles"/>
                                    <ComboBoxItem Content="Español"/>
                                </ComboBox>
                                <TextBlock Grid.Row="2" Text="Ayudará su experiencia de juego" FontSize="14" FontWeight="SemiBold" Foreground="#999999" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock x:Name="TextBlockLanguageError" Grid.Column="1" Text="Seleccione un idioma" FontSize="14" Foreground="Red" TextWrapping="Wrap" VerticalAlignment="Center" Margin="15,15,0,0" Visibility="Hidden"/>
                        </Grid>
                    </Grid>

                    <!-- Right Edit Panel -->
                    <Grid Grid.Column="1" Margin="20,10,20,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="25"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="25"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="25"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="25"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="25"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="25"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Nombre" FontSize="15" Foreground="#222222"/>
                        <TextBox x:Name="TextBoxFullName" Grid.Row="1" Height="35" FontSize="15" Padding="8,4"/>
                        <TextBlock x:Name="TextBlockFullNameError" Grid.Row="2" Text="Ingrese un nombre válido" FontSize="14" Foreground="Red" VerticalAlignment="Center" Visibility="Hidden"/>

                        <TextBlock Grid.Row="3" Text="Correo Electronico" FontSize="15" Foreground="#222222"/>
                        <TextBox x:Name="TextBoxEmail" Grid.Row="4" Height="35" FontSize="15" Padding="8,4" IsReadOnly="True" Background="#EDEDED"/>

                        <TextBlock Grid.Row="6" Text="Telefono" FontSize="15" Foreground="#222222"/>
                        <TextBox x:Name="TextBoxPhone" Grid.Row="7" Height="35" FontSize="15" Padding="8,4"/>
                        <TextBlock x:Name="TextBlockPhoneError" Grid.Row="8" Text="Coloque solo números (10 dígitos)" FontSize="14" Foreground="Red" VerticalAlignment="Center" Visibility="Hidden"/>

                        <TextBlock Grid.Row="9" Text="Contraseña Actual" FontSize="15" Foreground="#222222"/>
                        <Grid Grid.Row="10">
                            <PasswordBox x:Name="PasswordBoxCurrentPassword" Height="35" FontSize="15" Padding="8,4" PasswordChanged="PasswordBoxCurrentPassword_PasswordChanged"/>
                            <TextBlock x:Name="TextBlockCurrentPasswordPlaceholder" Text="Requerida para cambiar contraseña" FontSize="15" Foreground="#999999" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <TextBlock Text="⊘" FontSize="24" Foreground="#555555" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        </Grid>
                        <TextBlock x:Name="TextBlockCurrentPasswordError" Grid.Row="11" Text="Contraseña actual incorrecta" FontSize="14" Foreground="Red" VerticalAlignment="Center" Visibility="Hidden"/>

                        <TextBlock Grid.Row="12" Text="Nueva Contraseña" FontSize="15" Foreground="#222222"/>
                        <Grid Grid.Row="13">
                            <PasswordBox x:Name="PasswordBoxPassword" Height="35" FontSize="15" Padding="8,4" PasswordChanged="PasswordBoxPassword_PasswordChanged"/>
                            <TextBlock x:Name="TextBlockPasswordPlaceholder" Text="Dejar vacío si no desea cambiarla" FontSize="15" Foreground="#999999" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <TextBlock Text="⊘" FontSize="24" Foreground="#555555" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        </Grid>

                        <TextBlock Grid.Row="14" Text="Confirme Contraseña" FontSize="15" Foreground="#222222"/>
                        <Grid Grid.Row="15">
                            <PasswordBox x:Name="PasswordBoxConfirmPassword" Height="35" FontSize="15" Padding="8,4" PasswordChanged="PasswordBoxConfirmPassword_PasswordChanged"/>
                            <TextBlock x:Name="TextBlockConfirmPasswordPlaceholder" Text="Confirme nueva contraseña" FontSize="15" Foreground="#999999" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <TextBlock Text="⊘" FontSize="24" Foreground="#555555" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        </Grid>
                        <TextBlock x:Name="TextBlockPasswordError" Grid.Row="16" Text="Contraseña es diferente" FontSize="14" Foreground="Red" VerticalAlignment="Center" Visibility="Hidden"/>

                        <TextBlock Grid.Row="17" Text="Cumpleaños" FontSize="15" Foreground="#222222"/>
                        <DatePicker x:Name="DatePickerBirthDate" Grid.Row="18" Width="190" Height="35" FontSize="15" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="TextBlockBirthDateError" Grid.Row="19" Text="Seleccione una fecha" FontSize="14" Foreground="Red" VerticalAlignment="Center" Visibility="Hidden"/>
                    </Grid>
                </Grid>

                <!-- FOOTER ELEMENT -->
                <!-- Grid Footer Navigation (Visible in View Mode) -->
                <Border x:Name="GridFooterNavigation" Grid.Row="1" Background="#F7F7F7" BorderBrush="#2B2B2B" BorderThickness="0,2,0,0" Visibility="Visible">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ButtonMainMenu" Grid.Column="0" Content="Menu Principal  ⚔" FontSize="15" FontWeight="SemiBold" BorderThickness="0" Background="Transparent" Cursor="Hand" Click="ButtonMainMenu_Click"/>
                        <Button x:Name="ButtonProfile" Grid.Column="1" Content="Perfil  👤" FontSize="15" FontWeight="SemiBold" BorderThickness="0" Background="Transparent" Cursor="Hand" Click="ButtonProfile_Click"/>
                        <Button x:Name="ButtonHistory" Grid.Column="2" Content="Historial  ◴" FontSize="15" FontWeight="SemiBold" BorderThickness="0" Background="Transparent" Cursor="Hand" Click="ButtonHistory_Click"/>
                        <Button x:Name="ButtonScoreboard" Grid.Column="3" Content="Marcadores  🏆" FontSize="15" FontWeight="SemiBold" BorderThickness="0" Background="Transparent" Cursor="Hand" Click="ButtonScoreboard_Click"/>
                        <Button x:Name="ButtonSettings" Grid.Column="4" Content="Ajustes  ⚙" FontSize="15" FontWeight="SemiBold" BorderThickness="0" Background="Transparent" Cursor="Hand" Click="ButtonSettings_Click"/>
                    </Grid>
                </Border>

                <!-- Grid Footer Edit Actions (Visible in Edit Mode) -->
                <Border x:Name="GridFooterEdit" Grid.Row="1" Background="White" BorderBrush="#2B2B2B" BorderThickness="0,2,0,0" Visibility="Collapsed" Margin="20,0,20,0">
                    <Grid>
                        <Button x:Name="ButtonSave" Content="Guardar Cambios" Width="250" Height="38" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Center" Cursor="Hand" Click="ButtonSave_Click"/>
                        <Button x:Name="ButtonCancel" Content="Cancelar" Width="250" Height="38" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" Click="ButtonCancel_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
