<Page x:Class="LetterClashClient.Views.GUIWelcomeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      xmlns:controls="clr-namespace:LetterClashClient.Controls"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUIWelcomeView"
      Loaded="Page_Loaded"
      Background="#0B0E14">

  <Page.Resources>
    <Style x:Key="ModernPrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="#0B0E14"/>
      <Setter Property="Foreground" Value="#4DEEEA"/>
      <Setter Property="BorderBrush" Value="#4DEEEA"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
              <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
              </Border.Effect>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="true">
                <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                <Setter Property="Foreground" Value="#0B0E14"/>
                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="true">
                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#00A896"/>
                <Setter Property="Foreground" Value="#0B0E14"/>
                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="false">
                <Setter TargetName="border" Property="Background" Value="#181E29"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                <Setter Property="Foreground" Value="#4A5568"/>
                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ModernSecondaryButton" TargetType="Button">
      <Setter Property="Background" Value="#0B0E14"/>
      <Setter Property="Foreground" Value="#F649A7"/>
      <Setter Property="BorderBrush" Value="#E60067"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
              <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#9B004F" Opacity="0.6"/>
              </Border.Effect>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="true">
                <Setter TargetName="border" Property="Background" Value="#F649A7"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#F649A7"/>
                <Setter Property="Foreground" Value="#0B0E14"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="true">
                <Setter TargetName="border" Property="Background" Value="#9B004F"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#9B004F"/>
                <Setter Property="Foreground" Value="#F649A7"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="false">
                <Setter TargetName="border" Property="Background" Value="#181E29"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                <Setter Property="Foreground" Value="#4A5568"/>
                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Page.Resources>

  <Grid>
    <Grid.Background>
      <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
          <GeometryDrawing>
            <GeometryDrawing.Pen>
              <Pen Brush="#181E29" Thickness="1"/>
            </GeometryDrawing.Pen>
            <GeometryDrawing.Geometry>
              <GeometryGroup>
                <LineGeometry StartPoint="0,0" EndPoint="40,0"/>
                <LineGeometry StartPoint="0,0" EndPoint="0,40"/>
              </GeometryGroup>
            </GeometryDrawing.Geometry>
          </GeometryDrawing>
        </DrawingBrush.Drawing>
      </DrawingBrush>
    </Grid.Background>

    <!-- Starfield Background -->
    <controls:StarfieldBackground />

    <StackPanel VerticalAlignment="Center" 
                    HorizontalAlignment="Center" 
                    Width="400">

      <Image x:Name="ImageLogo"
                   Source="/Assets/Images/LetterClashLogo.png"
                   Width="400"
                   Height="170"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10">
        <Image.Effect>
          <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#00A896" Opacity="0.5"/>
        </Image.Effect>
      </Image>

      <TextBlock Text="{DynamicResource EntryMenu_Title}"
                       FontFamily="{StaticResource GeistPixelSquare}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#7DE2D1"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40">
        <TextBlock.Effect>
          <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#4DEEEA" Opacity="0.7"/>
        </TextBlock.Effect>
      </TextBlock>

      <Button x:Name="ButtonLogin"
                    Content="{DynamicResource EntryMenu_BtnLogin}"
                    Style="{StaticResource ModernPrimaryButton}"
                    Height="44"
                    Margin="0,0,0,16"
                    Click="ButtonLogin_Click"/>

      <Button x:Name="ButtonRegister"
                    Content="{DynamicResource EntryMenu_BtnRegister}"
                    Style="{StaticResource ModernSecondaryButton}"
                    Height="44"
                    Margin="0,0,0,16"
                    Click="ButtonRegister_Click"/>
    </StackPanel>
  </Grid>
</Page>
