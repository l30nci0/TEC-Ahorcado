<Page x:Class="LetterClashClient.Views.GameGuesser"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GameGuesser"
      Loaded="Page_Loaded">

    <Grid Background="#F4F4F4">
        <Border Margin="20"
            BorderBrush="#2B2B2B"
            BorderThickness="2"
            Background="White">

            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="85"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid x:Name="GridHeader"
              Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="330"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                  Width="240"
                  Height="58"
                  BorderBrush="#2B2B2B"
                  BorderThickness="1"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                         Text="."
                         FontSize="36"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1"
                         Text="Partida"
                         FontSize="20"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                  Width="300"
                  Height="50"
                  BorderBrush="#2B2B2B"
                  BorderThickness="1"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="65"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                         Text="Vs"
                         FontSize="17"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>

                            <TextBlock x:Name="TextBlockOpponent"
                         Grid.Column="1"
                         Text="Usuario 1"
                         FontSize="16"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"/>

                            <Image x:Name="ImageOpponentAvatar"
                     Grid.Column="2"
                     Source="/Assets/Images/UserAvatar.png"
                     Width="48"
                     Height="48"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Button x:Name="ButtonAbandon"
                  Grid.Column="2"
                  Content="Abandonar  ⚑"
                  Width="130"
                  Height="34"
                  FontSize="13"
                  FontWeight="SemiBold"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Cursor="Hand"
                  Click="ButtonAbandon_Click"/>

                    <Image x:Name="ImageLogo"
                 Grid.Column="3"
                 Source="/Assets/Images/LogoLetterClash.jpeg"
                 Width="250"
                 Height="70"
                 Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="1"
              Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60*"/>
                        <ColumnDefinition Width="40*"/>
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="GridLeftPanel"
                Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="170"/>
                            <RowDefinition Height="75"/>
                            <RowDefinition Height="170"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="TextBlockHiddenWord"
                       Grid.Row="1"
                       Text="_ _ _ _ _ _ _ _"
                       FontSize="34"
                       FontWeight="SemiBold"
                       Foreground="#1E1E2F"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                        <Grid Grid.Row="2"
                  Width="560"
                  Height="150"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="50"/>
                            </Grid.RowDefinitions>

                            <UniformGrid Grid.Row="0"
                           Columns="10">
                                <Button Content="Q" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="W" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="E" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="R" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="T" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="Y" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="U" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="I" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="O" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="P" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                            </UniformGrid>

                            <UniformGrid Grid.Row="1"
                           Columns="9"
                           Margin="24,0,24,0">
                                <Button Content="A" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="S" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="D" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="F" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="G" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="H" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="J" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="K" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="L" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                            </UniformGrid>

                            <UniformGrid Grid.Row="2"
                           Columns="7"
                           Margin="70,0,70,0">
                                <Button Content="Z" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="X" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="C" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="V" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="B" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="N" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                                <Button Content="M" Click="ButtonLetter_Click" FontSize="16" FontWeight="SemiBold" Margin="2"/>
                            </UniformGrid>
                        </Grid>
                    </Grid>

                    <Grid x:Name="GridRightPanel"
                Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="220"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="190"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Canvas x:Name="CanvasHangmanGame"
                    Grid.Row="0"
                    Width="280"
                    Height="210"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                            <Image x:Name="ImageHangman"
                     Source="/Assets/Images/Hangedman5.jpg"
                     Width="220"
                     Height="190"
                     Stretch="Uniform"
                     Canvas.Left="25"
                     Canvas.Top="10"/>

                            <Border x:Name="BorderUserAvatar"
                      Width="58"
                      Height="58"
                      CornerRadius="29"
                      BorderBrush="#2B2B2B"
                      BorderThickness="2"
                      Background="White"
                      Canvas.Left="173"
                      Canvas.Top="47">

                                <Image x:Name="ImageUserAvatar"
                       Source="/Assets/Images/UserAvatar.png"
                       Width="46"
                       Height="46"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                            </Border>
                        </Canvas>

                        <Grid Grid.Row="1"
                  Width="300"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="55"/>
                            </Grid.ColumnDefinitions>

                            <ProgressBar x:Name="ProgressBarAttempts"
                           Grid.Column="0"
                           Height="20"
                           Minimum="0"
                           Maximum="5"
                           Value="0"/>

                            <TextBlock x:Name="TextBlockAttempts"
                         Grid.Column="1"
                         Text="0/5"
                         FontSize="16"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="GridChat"
                  Grid.Row="2"
                  Width="360"
                  Height="180"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="32"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                      BorderBrush="#2B2B2B"
                      BorderThickness="1">
                                <TextBlock x:Name="TextBlockChatTitle"
                           Text="Chat con Usuario 1"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBox x:Name="TextBoxChatMessages"
                       Grid.Row="1"
                       FontSize="13"
                       IsReadOnly="True"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto"
                       BorderBrush="#2B2B2B"
                       BorderThickness="1"/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="TextBoxChatInput"
                         Grid.Column="0"
                         FontSize="13"
                         Padding="6,3"/>

                                <Button x:Name="ButtonSendMessage"
                        Grid.Column="1"
                        Content="Enviar"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="ButtonSendMessage_Click"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>