<Page x:Class="LetterClashClient.Views.GUICreateRoomView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUICreateRoomView"
      Loaded="Page_Loaded"
      Background="#0B0E14">

    <Page.Resources>
        <!-- Retro Grayscale Primary Button Style -->
        <Style x:Key="ModernPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A986" Opacity="0.3"/>
                                </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Foreground" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#181E29"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#52525B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Retro Grayscale Secondary Button Style -->
        <Style x:Key="ModernSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#F649A7"/>
            <Setter Property="BorderBrush" Value="#E60067"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#9B004F" Opacity="0.6"/>
                                </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#F649A7"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F649A7"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#E60067"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E60067"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#181E29"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#52525B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Bottom Navigation Bar Buttons -->
        <Style x:Key="NavBarButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A986" Opacity="0.6"/>
                                </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Foreground" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                            </Trigger>
                                <Trigger Property="IsPressed" Value="true">
                                    <Setter Property="Foreground" Value="#0B0E14"/>
                                    <Setter TargetName="border" Property="Background" Value="#00A986"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#00A986"/>
                                </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#181E29"/>
                                <Setter TargetName="border" Property="Background" Value="#0B0E14"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#181E29"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form Elements Generic Styles -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Modern Grid Line Background -->
        <Grid.Background>
            <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                <DrawingBrush.Drawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#15151A" Thickness="1"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,0" EndPoint="40,0"/>
                                <LineGeometry StartPoint="0,0" EndPoint="0,40"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </Grid.Background>

        <!-- Main Shell Grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Content Area -->
            <Grid Grid.Row="0">
                <!-- Main Card Container -->
                <Border Width="850"
                        Height="460"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        BorderBrush="#4DEEEA"
                        BorderThickness="1.5"
                        Background="#0B0E14"
                        CornerRadius="0"
                        Padding="35">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- Header -->
                            <RowDefinition Height="Auto"/>
                            <!-- Content (Form & Actions) -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header Section -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="{DynamicResource CreateRoom_Title}"
                                       FontFamily="{StaticResource GeistPixelSquare}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#4DEEEA"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="{DynamicResource CreateRoom_Subtitle}"
                                       FontFamily="{StaticResource GeistMono}"
                                       FontSize="13"
                                       Foreground="#4DEEEA"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Content Area -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <!-- Configuration (Left) -->
                                <ColumnDefinition Width="1.2*"/>
                                <!-- Divider -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Actions (Right) -->
                                <ColumnDefinition Width="0.8*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Column: Configuration -->
                            <StackPanel Grid.Column="0" Margin="0,0,30,0" VerticalAlignment="Center">
                                <!-- Game Type Selection -->
                                <TextBlock Text="{DynamicResource CreateRoom_TypeLabel}" Style="{StaticResource FormLabelStyle}"/>
                                <Grid Height="40" Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="ButtonTypePublic"
                                            Grid.Column="0"
                                            Content="{DynamicResource CreateRoom_BtnPublic}"
                                            Style="{StaticResource ModernSecondaryButton}"
                                            Margin="0,0,5,0"
                                            Click="ButtonTypePublic_Click"/>

                                    <Button x:Name="ButtonTypePrivate"
                                            Grid.Column="1"
                                            Content="{DynamicResource CreateRoom_BtnPrivate}"
                                            Style="{StaticResource ModernSecondaryButton}"
                                            Margin="5,0,0,0"
                                            Click="ButtonTypePrivate_Click"/>
                                </Grid>

                                <!-- Word Selection -->
                                <TextBlock Text="{DynamicResource CreateRoom_WordLabel}" Style="{StaticResource FormLabelStyle}"/>
                                <Button x:Name="ButtonSelectWord"
                                        Content="{DynamicResource CreateRoom_BtnSelectWord}"
                                        Height="42"
                                        Style="{StaticResource ModernSecondaryButton}"
                                        Margin="0,0,0,15"
                                        Click="ButtonSelectWord_Click"/>

                                <!-- Selected Word Display -->
                                <Border BorderBrush="#00A986" BorderThickness="1" Background="#0B0E14" Padding="15,10" Margin="0,0,0,15">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A986" Opacity="0.3"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                                                              <TextBlock Text="{DynamicResource CreateRoom_WordSelectedLabel}" 
                                                   FontFamily="{StaticResource GeistMono}" 
                                                   FontSize="12" 
                                                   FontWeight="Bold" 
                                                   Foreground="#4DEEEA" 
                                                   VerticalAlignment="Center"/>
                                        
                                        <TextBlock x:Name="TextBlockSelectedWord" 
                                                   Grid.Column="1"
                                                   Text="" 
                                                   FontFamily="{StaticResource GeistMono}" 
                                                   FontSize="13" 
                                                   FontWeight="Bold" 
                                                   Foreground="#4DEEEA" 
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"/>
                                    </Grid>
                                </Border>
 
                                <!-- Visual Selected Language Display -->
                                <TextBlock Text="{DynamicResource CreateRoom_LangLabel}" Style="{StaticResource FormLabelStyle}"/>
                                <Border BorderBrush="#00A986" BorderThickness="1" Background="#0B0E14" Padding="15,8" Margin="0,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A986" Opacity="0.3"/> 
                                    </Border.Effect>
                                    <TextBlock x:Name="TextBlockSelectedLanguageLabel" 
                                               Text="{DynamicResource CreateRoom_LangNone}" 
                                               FontFamily="{StaticResource GeistMono}" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Foreground="#4DEEEA" 
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <!-- Divider -->
                        <Border Grid.Column="1" Width="1.5" Background="#4DEEEA" VerticalAlignment="Stretch" Margin="0,10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#4DEEEA" Opacity="0.5"/>
                            </Border.Effect>
                        </Border>

              <!-- Right Column: Actions -->
                            <Grid Grid.Column="2" Margin="30,0,0,0" VerticalAlignment="Center">
                                <!-- Primary Buttons -->
                                <StackPanel VerticalAlignment="Center">
                                    <Button x:Name="ButtonCreateRoom"
                                            Content="{DynamicResource CreateRoom_BtnCreate}"
                                            Height="46"
                                            Style="{StaticResource ModernPrimaryButton}"
                                            Margin="0,0,0,10"
                                            Click="ButtonCreateRoom_Click"/>
 
                                    <Button x:Name="ButtonBack"
                                            Content="{DynamicResource CreateRoom_BtnBack}"
                                            Height="46"
                                            Style="{StaticResource ModernSecondaryButton}"
                                            Click="ButtonBack_Click"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 1: Bottom Navigation Bar Tray -->
            <Border Grid.Row="1"
                    BorderBrush="#2D2D30"
                    BorderThickness="0,1,0,0"
                    Background="#121214">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ButtonMainMenu"
                            Grid.Column="0"
                            Content="{DynamicResource Nav_MainMenu}"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonMainMenu_Click"/>

                    <Button x:Name="ButtonProfile"
                            Grid.Column="1"
                            Content="{DynamicResource Nav_Profile}"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonProfile_Click"/>

                    <Button x:Name="ButtonHistory"
                            Grid.Column="2"
                            Content="{DynamicResource Nav_History}"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonHistory_Click"/>

                    <Button x:Name="ButtonScoreboard"
                            Grid.Column="3"
                            Content="{DynamicResource Nav_Scoreboard}"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonScoreboard_Click"/>

                    <Button x:Name="ButtonSettings"
                            Grid.Column="4"
                            Content="{DynamicResource Nav_Settings}"
                            Style="{StaticResource NavBarButton}"
                            Click="ButtonSettings_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Hidden elements to preserve code-behind field references -->
        <Grid Visibility="Collapsed">
            <ComboBox x:Name="ComboBoxLanguage">
                <ComboBoxItem Content="Seleccione Idioma"/>
                <ComboBoxItem Content="Ingles"/>
                <ComboBoxItem Content="Español"/>
            </ComboBox>
            <ComboBox x:Name="ComboBoxGameType">
                <ComboBoxItem Content="Seleccione Partida"/>
                <ComboBoxItem Content="Publica"/>
                <ComboBoxItem Content="Privada"/>
            </ComboBox>
            <TextBlock x:Name="TextBlockUsername"/>
            <TextBlock x:Name="TextBlockAge"/>
            <Image x:Name="ImageUserAvatar"/>
        </Grid>
    </Grid>
</Page>
