<Page x:Class="LetterClashClient.Views.GUIBattleHistoryDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUIBattleHistoryDetailView"
      Loaded="Page_Loaded">

    <Grid Background="#F4F4F4">
        <Border Margin="20"
            BorderBrush="#2B2B2B"
            BorderThickness="2"
            Background="White">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
              Margin="30,25,30,15">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52*"/>
                        <ColumnDefinition Width="48*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="85"/>
                            <RowDefinition Height="360"/>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="BorderHeaderMatch"
                    Grid.Row="0"
                    Width="300"
                    Height="65"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                            Text="."
                            FontSize="42"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                            Text="Partida"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Foreground="#111111"
                            VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border x:Name="BorderBattleInfo"
                    Grid.Row="1"
                    Width="600"
                    Height="340"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">

                            <Grid Margin="25">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="60"/>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                        Width="380"
                        Height="45"
                        BorderBrush="#2B2B2B"
                        BorderThickness="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                                    <TextBlock x:Name="TextBlockRole"
                              Text="Tu Rol fue:"
                              FontSize="19"
                              FontWeight="SemiBold"
                              Foreground="#111111"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                                </Border>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <Image x:Name="ImageEnemyAvatar"
                          Grid.Column="0"
                          Source="/Assets/Images/UserAvatar.png"
                          Width="58"
                          Height="58"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

                                    <TextBlock x:Name="TextBlockRival"
                              Grid.Column="1"
                              FontSize="19"
                              FontWeight="SemiBold"
                              Foreground="#111111"
                              VerticalAlignment="Center"/>

                                    <Button x:Name="ButtonViewProfile"
                           Grid.Column="2"
                           Content="Ver Perfil"
                           Width="100"
                           Height="32"
                           FontSize="14"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Cursor="Hand"
                           Click="ButtonViewProfile_Click"/>
                                </Grid>

                                <TextBlock x:Name="TextBlockLanguage"
                            Grid.Row="2"
                            FontSize="19"
                            FontWeight="SemiBold"
                            Foreground="#111111"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                                <TextBlock x:Name="TextBlockWord"
                            Grid.Row="3"
                            FontSize="19"
                            FontWeight="SemiBold"
                            Foreground="#111111"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                                <TextBlock x:Name="TextBlockType"
                            Grid.Row="4"
                            FontSize="19"
                            FontWeight="SemiBold"
                            Foreground="#111111"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                                <TextBlock x:Name="TextBlockDate"
                            Grid.Row="5"
                            FontSize="19"
                            FontWeight="SemiBold"
                            Foreground="#111111"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Button x:Name="ButtonBack"
                    Grid.Row="2"
                    Content="Regresar  ↩"
                    Width="180"
                    Height="40"
                    FontSize="16"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    Click="ButtonBack_Click"/>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="95"/>
                            <RowDefinition Height="250"/>
                            <RowDefinition Height="55"/>
                            <RowDefinition Height="130"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Image x:Name="ImageLogo"
                    Grid.Row="0"
                    Source="/Assets/Images/LogoLetterClash.jpeg"
                    Width="300"
                    Height="90"
                    Stretch="Uniform"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                        <Canvas x:Name="CanvasHangmanBattle"
                    Grid.Row="1"
                    Width="330"
                    Height="240"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                            <Image x:Name="ImageHangman"
                      Source="/Assets/Images/Hangedman1.jpg"
                      Width="280"
                      Height="230"
                      Stretch="Uniform"
                      Canvas.Left="20"
                      Canvas.Top="5"/>

                            <Border x:Name="BorderUserAvatar"
                       Width="66"
                       Height="66"
                       CornerRadius="33"
                       BorderBrush="#2B2B2B"
                       BorderThickness="2"
                       Background="White"
                       Canvas.Left="190"
                       Canvas.Top="50">

                                <Image x:Name="ImageUserAvatar"
                        Source="/Assets/Images/UserAvatar.png"
                        Width="52"
                        Height="52"
                        Stretch="Uniform"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                            </Border>
                        </Canvas>

                        <Grid Grid.Row="2"
                  Width="360"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <ProgressBar x:Name="ProgressBarBattle"
                            Grid.Column="0"
                            Height="25"
                            Minimum="0"
                            Maximum="5"/>

                            <TextBlock x:Name="TextBlockProgress"
                          Grid.Column="1"
                          FontSize="17"
                          FontWeight="SemiBold"
                          Foreground="#111111"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Row="3"
                  Width="430"
                  Height="110"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                          HorizontalAlignment="Center"
                           VerticalAlignment="Center">

                                <TextBlock Text="Estado de la partida:"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="#111111"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,18"/>

                                <TextBlock x:Name="TextBlockBattleStatus"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="#111111"
                            HorizontalAlignment="Center"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                       Width="2"
                       Background="#2B2B2B"
                       VerticalAlignment="Stretch"
                       Margin="0,10,0,10"/>

                            <StackPanel Grid.Column="2"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">

                                <TextBlock Text="Puntaje:"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="#111111"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,18"/>

                                <TextBlock x:Name="TextBlockScore"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="#111111"
                            HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>

                <Border Grid.Row="1"
                BorderBrush="#2B2B2B"
                BorderThickness="0,2,0,0"
                Background="#F7F7F7">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ButtonMainMenu"
                    Grid.Column="0"
                    Content="Menu Principal  ⚔"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonMainMenu_Click"/>

                        <Button x:Name="ButtonProfile"
                    Grid.Column="1"
                    Content="Perfil  👤"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonProfile_Click"/>

                        <Button x:Name="ButtonHistory"
                    Grid.Column="2"
                    Content="Historial  ◴"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonHistory_Click"/>

                        <Button x:Name="ButtonScoreboard"
                    Grid.Column="3"
                    Content="Marcadores  🏆"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonScoreboard_Click"/>

                        <Button x:Name="ButtonSettings"
                    Grid.Column="4"
                    Content="Ajustes  ⚙"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonSettings_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
