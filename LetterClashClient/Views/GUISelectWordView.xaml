<Page x:Class="LetterClashClient.Views.GUISelectWordView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUISelectWordView"
      Loaded="Page_Loaded"
      Background="#0B0E14">

    <Page.Resources>
        <!-- Retro Grayscale Primary Button Style -->
        <Style x:Key="ModernPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#4DEEEA" Opacity="0.6"/>
                                </Border.Effect>
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00A896"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#27272A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#71717A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Retro Grayscale Secondary Button Style -->
        <Style x:Key="ModernSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#F649A7"/>
            <Setter Property="BorderBrush" Value="#E60067"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#9B004F" Opacity="0.6"/>
                                </Border.Effect>
                          <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#F649A7"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F649A7"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#E60067"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E60067"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#181E29"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#52525B"/>
                                <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="0" ShadowDepth="0" Color="#000000" Opacity="0"/>
                                </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form Elements Generic Styles -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00A896"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>

        <!-- DataGrid Dark Grayscale Styles -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="BorderBrush" Value="#00A896"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#181E29"/>
            <Setter Property="VerticalGridLinesBrush" Value="#181E29"/>
            <Setter Property="RowBackground" Value="#0B0E14"/>
            <Setter Property="AlternatingRowBackground" Value="#181E29"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#181E29"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#00A896"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4DEEEA"/>
                    <Setter Property="Foreground" Value="#0B0E14"/>
                    <Setter Property="BorderBrush" Value="#4DEEEA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderBrush" Value="#00A896"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Modern Grid Line Background -->
        <Grid.Background>
            <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                <DrawingBrush.Drawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#15151A" Thickness="1"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,0" EndPoint="40,0"/>
                                <LineGeometry StartPoint="0,0" EndPoint="0,40"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </Grid.Background>

        <!-- Main Card Container -->
        <Border Width="950"
                Height="540"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                BorderBrush="#4DEEEA"
                BorderThickness="1.5"
                Background="#0B0E14"
                CornerRadius="0"
                Padding="35">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#4DEEEA" Opacity="0.6"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- DataGrid Content -->
                    <RowDefinition Height="*"/>
                    <!-- Bottom Action -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header Section -->
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="{DynamicResource SelectWord_Title}"
                               FontFamily="{StaticResource GeistPixelSquare}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#4DEEEA"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>

                    <TextBlock x:Name="TextBlockHeader"
                               Text=""
                               FontFamily="{StaticResource GeistMono}"
                               FontSize="13"
                               Foreground="#4DEEEA"
                               HorizontalAlignment="Center"/>

                    <!-- Segmented Buttons for Language Selection -->
                    <Grid Width="300" Height="36" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="ButtonLangES"
                                Grid.Column="0"
                                Content="{DynamicResource SelectWord_LangES}"
                                Style="{StaticResource ModernPrimaryButton}"
                                Margin="0,0,5,0"
                                FontSize="12"
                                Click="ButtonLangES_Click"/>
                                
                        <Button x:Name="ButtonLangEN"
                                Grid.Column="1"
                                Content="{DynamicResource SelectWord_LangEN}"
                                Style="{StaticResource ModernSecondaryButton}"
                                Margin="5,0,0,0"
                                FontSize="12"
                                Click="ButtonLangEN_Click"/>
                    </Grid>
                </StackPanel>

                <!-- Words DataGrid Content Area -->
                <DataGrid x:Name="DataGridWords"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          Background="#0B0E14"
                          Margin="0,10,0,20">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource SelectWord_ColWord}"
                                            Binding="{Binding PalabraTexto}"
                                            Width="110"/>

                        <DataGridTextColumn Header="{DynamicResource SelectWord_ColDescription}"
                                            Binding="{Binding Descripcion}"
                                            Width="*"/>

                        <DataGridTemplateColumn Header="{DynamicResource SelectWord_ColAction}"
                                                Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{DynamicResource SelectWord_BtnUse}"
                                            Width="105"
                                            Height="26"
                                            Style="{StaticResource ModernPrimaryButton}"
                                            FontSize="11"
                                            Click="ButtonUseWord_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Bottom Action Row -->
                <Grid Grid.Row="2">
                    <Button x:Name="ButtonBack"
                            Content="{DynamicResource SelectWord_BtnBack}"
                            Width="150"
                            Height="40"
                            Style="{StaticResource ModernSecondaryButton}"
                            HorizontalAlignment="Left"
                            Click="ButtonBack_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
