<Page x:Class="LetterClashClient.Views.GUIRegisterView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUIRegisterView"
      Loaded="Page_Loaded"
      Background="#0B0E14">

    <Page.Resources>
        <!-- Modern Dark Grayscale TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="CaretBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Background" Value="#111622"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="Background" Value="#181E29"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Dark Grayscale PasswordBox Style -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="CaretBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect x:Name="NeonGlow"
                                          Color="#00A896"
                                          BlurRadius="8"
                                          ShadowDepth="0"
                                          Opacity="0.4"/>
                            </Border.Effect>
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Value="#111622" Property="Background"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter TargetName="border" Value="#181E29" Property="Background"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Retro Grayscale Primary Button Style -->
        <Style x:Key="ModernPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#00A896"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00A896"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#181E29"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#52525B"/>
                                <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="0" ShadowDepth="0" Color="#000000" Opacity="0"/>
                                </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Retro Grayscale Secondary Button Style -->
        <Style x:Key="ModernSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="Foreground" Value="#F649A7"/>
            <Setter Property="BorderBrush" Value="#E60067"/>
            <Setter Property="FontFamily" Value="{StaticResource GeistPixelSquare}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0" 
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                               <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#9B004F" Opacity="0.6"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#F649A7"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F649A7"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#E60067"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E60067"/>
                                <Setter Property="Foreground" Value="#0B0E14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#181E29"/>
                                 <Setter TargetName="border" Property="BorderBrush" Value="#27272A"/>
                                 <Setter Property="Foreground" Value="#52525B"/>
                                 <Setter TargetName="border" Property="Effect">
                                      <Setter.Value>
                                        <DropShadowEffect BlurRadius="0" ShadowDepth="0" Color="#000000" Opacity="0"/>
                                    </Setter.Value>
                                 </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ComboBox Templates & Styles -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="border"
                    Background="#0B0E14"
                    BorderBrush="#00A896"
                    BorderThickness="1.5"
                    CornerRadius="0"
                    SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect x:Name="NeonGlow" 
                              BlurRadius="8" 
                              ShadowDepth="0" 
                              Color="#00A896" 
                              Opacity="0.4"/>
                        </Border.Effect>
                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>
                    <!-- Custom Arrow Box -->
                    <Border Grid.Column="1" 
                            BorderBrush="#00A896" 
                            BorderThickness="1,0,0,0" 
                            Background="#181E29">
                        <TextBlock Text="▼" 
                                   Foreground="#4DEEEA" 
                                   FontFamily="{StaticResource GeistMono}"
                                   FontSize="10"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                <Setter TargetName="border" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#4DEEEA" Opacity="0.8"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="border" Property="Background" Value="#4DEEEA"/>
                    <Setter TargetName="border" Property="BorderBrush" Value="#4DEEEA"/>
                    <Setter TargetName="border" Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#4DEEEA" Opacity="0.9"/>
                    </Setter.Value>
                    </Setter>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="Background" Value="#0B0E14"/>
            <Setter Property="BorderBrush" Value="#4DEEEA"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Template="{StaticResource ComboBoxToggleButton}" 
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                          ClickMode="Press"/>
                            
                            <ContentPresenter x:Name="ContentSite" 
                                              IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="12,0,40,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            
                            <Popup x:Name="Popup" 
                                   Placement="Bottom" 
                                   IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" 
                                   Focusable="False" 
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" 
                                      SnapsToDevicePixels="True" 
                                      MinWidth="{TemplateBinding ActualWidth}" 
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" 
                                            Background="#0B0E14" 
                                            BorderBrush="#00A896"
                                            BorderThickness="1.5" 
                                            CornerRadius="0"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom DatePicker Template & Style -->
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid x:Name="PART_Root" HorizontalAlignment="{TemplateBinding HorizontalAlignment}" VerticalAlignment="{TemplateBinding VerticalAlignment}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               Focusable="{TemplateBinding Focusable}"
                                               HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                               VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                               Background="#0B0E14"
                                               Foreground="#4DEEEA"
                                               CaretBrush="#4DEEEA"
                                               BorderThickness="1.5,1.5,0,1.5"
                                               BorderBrush="#00A896"
                                               Padding="10,6"
                                               FontFamily="{StaticResource GeistMono}"
                                               FontSize="14"/>
                                               
                            <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    Width="36"
                                    Focusable="False"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="btnBorder"
                                                Background="#0B0E14"
                                                BorderBrush="#4DEEEA"
                                                BorderThickness="1,1.5,1.5,1.5"
                                                CornerRadius="0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#00A896" Opacity="0.6"/>
                                        </Border.Effect>
                                            <TextBlock x:Name="btnIcon"
                                                       Text="📅" 
                                                       Foreground="#4DEEEA"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btnBorder" Property="BorderBrush" Value="#4DEEEA"/>
                                                <Setter TargetName="btnBorder" Property="Background" Value="#4DEEEA"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="btnBorder" Property="Background" Value="#00A896"/>
                                                <Setter TargetName="btnBorder" Property="BorderBrush" Value="#00A896"/>
                                                <Setter TargetName="btnIcon" Property="Foreground" Value="#0B0E14"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#0B0E14"
                                        BorderBrush="#00A896"
                                        BorderThickness="1.5"
                                        Padding="5"
                                        CornerRadius="0">
                                    <Calendar x:Name="PART_Calendar"
                                              Background="#0B0E14"
                                              Foreground="#4DEEEA"
                                              BorderThickness="0">
                                        <Calendar.Resources>
                                            <Style TargetType="CalendarButton">
                                                <Setter Property="Background" Value="#0B0E14"/>
                                                <Setter Property="Foreground" Value="#4DEEEA"/>
                                            </Style>
                                            <Style TargetType="CalendarDayButton">
                                                <Setter Property="Background" Value="#0B0E14"/>
                                                <Setter Property="Foreground" Value="#4DEEEA"/>
                                            </Style>
                                        </Calendar.Resources>
                                    </Calendar>
                                </Border>
                            </Popup>
                        </Grid>
                      <ControlTemplate.Triggers>
                          <Trigger Property="IsEnabled" Value="False">
                              <Setter TargetName="PART_TextBox" Property="Background" Value="#181E29"/>
                              <Setter TargetName="PART_TextBox" Property="BorderBrush" Value="#27272A"/>
                              <Setter TargetName="PART_TextBox" Property="Foreground" Value="#52525B"/>
                              <Setter TargetName="PART_TextBox" Property="Effect">
                              <Setter.Value>
                                  <DropShadowEffect BlurRadius="0" ShadowDepth="0" Color="#000000" Opacity="0"/>
                              </Setter.Value>
                              </Setter>
                          </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form Elements Generic Styles -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4EEEDA"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>

        <Style x:Key="PlaceholderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#4DEEEA"/>
            <Setter Property="Margin" Value="14,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <Style x:Key="ErrorLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GeistMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#E60067"/>
            <Setter Property="Margin" Value="2,2,0,12"/>
            <Setter Property="Visibility" Value="Hidden"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Modern Grid Line Background -->
        <Grid.Background>
            <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                <DrawingBrush.Drawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#15151A" Thickness="1"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,0" EndPoint="40,0"/>
                                <LineGeometry StartPoint="0,0" EndPoint="0,40"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </Grid.Background>

        <!-- Main Card Container -->
        <Border Width="950"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                BorderBrush="#2D2D30"
                BorderThickness="1"
                Background="#0B0E14"
                CornerRadius="0"
                Padding="35">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#00A896" Opacity="0.3"/>
        </Border.Effect>

      <Grid>
                <Grid.RowDefinitions>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Columns -->
                    <RowDefinition Height="*"/>
                    <!-- Bottom Buttons -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header Title -->
                <TextBlock Grid.Row="0"
                           Text="CREAR CUENTA"
                           FontFamily="{StaticResource GeistPixelSquare}"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#4DEEEA"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- Two Column Form Grid -->
                <Grid Grid.Row="1" Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <!-- Divider Spacer -->
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: Account Info -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ACCESO DE USUARIO"
                                   FontFamily="{StaticResource GeistPixelSquare}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#4DEEEA"
                                   Margin="0,0,0,16"/>

                        <!-- Username -->
                        <TextBlock Text="NOMBRE DE USUARIO" Style="{StaticResource FormLabelStyle}"/>
                        <Grid Margin="0,0,0,2">
                            <TextBox x:Name="TextBoxUsername" Style="{StaticResource ModernTextBox}" Height="40" TextChanged="TextBoxUsername_TextChanged"/>
                            <TextBlock x:Name="TextBlockUsernamePlaceholder" Text="Nombre de Usuario" Style="{StaticResource PlaceholderStyle}"/>
                        </Grid>
                        <TextBlock x:Name="TextBlockUsernameError" Text="Ingrese un Usuario/Nombre ya en Uso" Style="{StaticResource ErrorLabelStyle}"/>

                        <!-- Email -->
                        <TextBlock Text="CORREO ELECTRÓNICO" Style="{StaticResource FormLabelStyle}"/>
                        <Grid Margin="0,0,0,2">
                            <TextBox x:Name="TextBoxEmail" Style="{StaticResource ModernTextBox}" Height="40" TextChanged="TextBoxEmail_TextChanged"/>
                            <TextBlock x:Name="TextBlockEmailPlaceholder" Text="correo@dominio.com" Style="{StaticResource PlaceholderStyle}"/>
                        </Grid>
                        <TextBlock x:Name="TextBlockEmailError" Text="Dominio no válido" Style="{StaticResource ErrorLabelStyle}"/>

                        <!-- Password -->
                        <TextBlock Text="CONTRASEÑA" Style="{StaticResource FormLabelStyle}"/>
                        <Grid Margin="0,0,0,16">
                            <PasswordBox x:Name="PasswordBoxPassword" Style="{StaticResource ModernPasswordBox}" Height="40" PasswordChanged="PasswordBoxPassword_PasswordChanged"/>
                            <TextBlock x:Name="TextBlockPasswordPlaceholder" Text="Ingresa tu contraseña" Style="{StaticResource PlaceholderStyle}"/>
                        </Grid>

                        <!-- Confirm Password -->
                        <TextBlock Text="CONFIRMAR CONTRASEÑA" Style="{StaticResource FormLabelStyle}"/>
                        <Grid Margin="0,0,0,2">
                            <PasswordBox x:Name="PasswordBoxConfirmPassword" Style="{StaticResource ModernPasswordBox}" Height="40" PasswordChanged="PasswordBoxConfirmPassword_PasswordChanged"/>
                            <TextBlock x:Name="TextBlockConfirmPasswordPlaceholder" Text="Confirma tu contraseña" Style="{StaticResource PlaceholderStyle}"/>
                        </Grid>
                        <TextBlock x:Name="TextBlockPasswordError" Text="Contraseña es diferente" Style="{StaticResource ErrorLabelStyle}"/>
                    </StackPanel>

                    <!-- Center Divider -->
                    <Border Grid.Column="1" 
                            BorderBrush="#4DEEEA" 
                            BorderThickness="1,0,0,0" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Stretch"/>

                    <!-- Right Column: Personal Info -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="INFORMACIÓN PERSONAL"
                                   FontFamily="{StaticResource GeistPixelSquare}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#4DEEEA"
                                   Margin="0,0,0,16"/>

                        <!-- Full Name -->
                        <TextBlock Text="NOMBRE COMPLETO" Style="{StaticResource FormLabelStyle}"/>
                        <Grid Margin="0,0,0,2">
                            <TextBox x:Name="TextBoxFullName" Style="{StaticResource ModernTextBox}" Height="40" TextChanged="TextBoxFullName_TextChanged"/>
                            <TextBlock x:Name="TextBlockFullNamePlaceholder" Text="Nombre Completo" Style="{StaticResource PlaceholderStyle}"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="2,2,0,6">
                            <TextBlock x:Name="TextBlockFullNameError" Text="¿Está seguro de que ese es su nombre?" FontFamily="{StaticResource GeistMono}" FontSize="11" Foreground="#F87171" VerticalAlignment="Center" Visibility="Hidden"/>
                            <Button x:Name="ButtonConfirmName" Content="SÍ" Width="45" Height="20" Margin="10,0,0,0" Style="{StaticResource ModernPrimaryButton}" FontSize="10" Visibility="Hidden"/>
                        </StackPanel>

                        <!-- Phone -->
                        <TextBlock Text="TELÉFONO" Style="{StaticResource FormLabelStyle}"/>
                        <Grid Margin="0,0,0,2">
                            <TextBox x:Name="TextBoxPhone" Style="{StaticResource ModernTextBox}" Height="40" TextChanged="TextBoxPhone_TextChanged"/>
                            <TextBlock x:Name="TextBlockPhonePlaceholder" Text="Número Telefónico" Style="{StaticResource PlaceholderStyle}"/>
                        </Grid>
                        <TextBlock x:Name="TextBlockPhoneError" Text="Coloque solo números" Style="{StaticResource ErrorLabelStyle}"/>

                        <!-- ComboBox and DatePicker row -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Birthday -->
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="FECHA NACIMIENTO" Style="{StaticResource FormLabelStyle}"/>
                                <DatePicker x:Name="DatePickerBirthDate" 
                                            Style="{StaticResource ModernDatePicker}"
                                            Height="40"
                                            HorizontalAlignment="Stretch"/>
                                <TextBlock x:Name="TextBlockBirthDateError" Text="Seleccione fecha" Style="{StaticResource ErrorLabelStyle}" Margin="2,4,0,0"/>
                            </StackPanel>

                            <!-- Preferred Language -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="IDIOMA PREFERIDO" Style="{StaticResource FormLabelStyle}"/>
                                
                                <!-- Segmented Buttons for Language Selection -->
                                <Grid Height="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Button x:Name="ButtonLangES"
                                            Grid.Column="0"
                                            Content="ESPAÑOL"
                                            Style="{StaticResource ModernPrimaryButton}"
                                            Margin="0,0,5,0"
                                            Click="ButtonLangES_Click"/>
                                            
                                    <Button x:Name="ButtonLangEN"
                                            Grid.Column="1"
                                            Content="ENGLISH"
                                            Style="{StaticResource ModernSecondaryButton}"
                                            Margin="5,0,0,0"
                                            Click="ButtonLangEN_Click"/>
                                </Grid>
                                
                                <!-- Hidden ComboBox to preserve code-behind field and index references -->
                                <ComboBox x:Name="ComboBoxPreferredLanguage"
                                          SelectedIndex="2"
                                          Visibility="Collapsed">
                                    <ComboBoxItem Content="Seleccionar Idioma"/>
                                    <ComboBoxItem Content="Ingles"/>
                                    <ComboBoxItem Content="Español"/>
                                </ComboBox>
                                
                                <TextBlock x:Name="TextBlockLanguageError" Text="Seleccione un idioma" Style="{StaticResource ErrorLabelStyle}" Margin="2,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Avatar Section -->
                        <TextBlock Text="AVATAR DE JUGADOR" Style="{StaticResource FormLabelStyle}"/>
                        <Grid HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Picture frame -->
                            <Border Grid.Column="0" 
                                    Width="90" 
                                    Height="90" 
                                    BorderBrush="#4DEEEA" 
                                    BorderThickness="1.5" 
                                    Background="#0B0E14" 
                                    CornerRadius="0">
                                <Grid>
                                    <Image x:Name="ImageUserAvatar"
                                           Source="/Assets/Images/UserAvatar.png"
                                           Width="80"
                                           Height="80"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                    <Button x:Name="ButtonAddAvatar"
                                            Content="+"
                                            Width="24"
                                            Height="24"
                                            FontSize="14"
                                            BorderBrush="#4DEEEA"
                                            FontFamily="{StaticResource GeistPixelSquare}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Cursor="Hand"
                                            Margin="0,0,2,2"
                                            Click="ButtonAddAvatar_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#4DEEEA"
                                                        BorderBrush="#4DEEEA"
                                                        BorderThickness="1"
                                                        CornerRadius="0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>

                            <TextBlock Grid.Column="1" 
                                       VerticalAlignment="Center" 
                                       Margin="15,0,0,0" 
                                       TextWrapping="Wrap" 
                                       Foreground="#4DEEEA" 
                                       FontSize="11" 
                                       FontFamily="{StaticResource GeistMono}"
                                       MaxWidth="220">
                                Selecciona una imagen personalizada para identificarte en partidas.
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Actions row -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ButtonCreate"
                            Grid.Column="0"
                            Content="CREAR CUENTA"
                            Style="{StaticResource ModernPrimaryButton}"
                            Height="44"
                            Margin="0,0,10,0"
                            Click="ButtonCreate_Click"/>

                    <Button x:Name="ButtonCancel"
                            Grid.Column="1"
                            Content="CANCELAR"
                            Style="{StaticResource ModernSecondaryButton}"
                            Height="44"
                            Margin="10,0,0,0"
                            Click="ButtonCancel_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
