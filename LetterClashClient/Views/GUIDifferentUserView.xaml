<Page x:Class="LetterClashClient.Views.GUIDifferentUserView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUIDifferentUserView"
      Loaded="Page_Loaded">

    <Grid Background="#F4F4F4">
        <Border Margin="20"
            BorderBrush="#2B2B2B"
            BorderThickness="2"
            Background="White">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
              Margin="25">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56*"/>
                        <ColumnDefinition Width="44*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="75"/>
                            <RowDefinition Height="300"/>
                            <RowDefinition Height="55"/>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                    Width="270"
                    Height="55"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">

                            <TextBlock x:Name="TextBlockUsernameHeader"
                          Text="&quot;NOMBRE DE USUARIO&quot;"
                          FontSize="18"
                          FontWeight="SemiBold"
                          Foreground="#111111"
                          VerticalAlignment="Center"
                          Margin="15,0,0,0"/>
                        </Border>

                        <Border Grid.Row="1"
                    Width="640"
                    Height="285"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">

                            <Grid Margin="25">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="70"/>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                              Text="Nombre:"
                              FontSize="16"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"/>

                                    <TextBlock x:Name="TextBlockFullName"
                              Grid.Column="1"
                              FontSize="16"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"
                              TextDecorations="Underline"/>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                              Text="Edad:"
                              FontSize="16"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"/>

                                    <TextBlock x:Name="TextBlockAge"
                              Grid.Column="1"
                              FontSize="16"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"
                              TextDecorations="Underline"/>

                                    <TextBlock Grid.Column="2"
                              Text="Cumple:"
                              FontSize="16"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"/>

                                    <TextBlock x:Name="TextBlockBirthDate"
                              Grid.Column="3"
                              FontSize="16"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"
                              TextDecorations="Underline"/>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="35"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                              Text="Correo Electrónico:"
                              FontSize="16"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"/>

                                    <TextBlock x:Name="TextBlockEmail"
                              Grid.Row="1"
                              FontSize="16"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"
                              TextDecorations="Underline"/>
                                </Grid>

                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                              Text="Teléfono:"
                              FontSize="16"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"/>

                                    <TextBlock x:Name="TextBlockPhone"
                              Grid.Column="1"
                              FontSize="16"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"
                              TextDecorations="Underline"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                    Width="640"
                    Height="32"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    Background="#D9D9D9"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="TextBlockTotalWins"
                            Grid.Column="0"
                            FontSize="14"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                                <TextBlock x:Name="TextBlockPercentWins"
                            Grid.Column="1"
                            FontSize="14"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                                <TextBlock x:Name="TextBlockTotalLosses"
                            Grid.Column="2"
                            FontSize="14"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                                <TextBlock x:Name="TextBlockPercentLosses"
                            Grid.Column="3"
                            FontSize="14"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                                <TextBlock x:Name="TextBlockTotalDisconnected"
                            Grid.Column="4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                                <TextBlock x:Name="TextBlockPercentDisconnected"
                            Grid.Column="5"
                            FontSize="14"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Button x:Name="ButtonBack"
                     Grid.Row="3"
                     Content="Regresar  ↩"
                     Width="180"
                     Height="38"
                     FontSize="15"
                     FontWeight="SemiBold"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Center"
                     Cursor="Hand"
                     Click="ButtonBack_Click"/>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="110"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Image x:Name="ImageLogo"
                    Grid.Row="0"
                    Source="/Assets/Images/LogoLetterClash.jpeg"
                    Width="330"
                    Height="95"
                    Stretch="Uniform"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                        <Canvas x:Name="CanvasHangmanDifferentUser"
                    Grid.Row="1"
                    Width="340"
                    Height="380"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,20,0,0">

                            <Image x:Name="ImageHangman"
                      Source="/Assets/Images/Hangedman1.jpg"
                      Width="300"
                      Height="340"
                      Stretch="Uniform"
                      Canvas.Left="20"
                      Canvas.Top="15"/>

                            <Border x:Name="BorderUserAvatar"
                       Width="74"
                       Height="74"
                       CornerRadius="37"
                       BorderBrush="#2B2B2B"
                       BorderThickness="2"
                       Background="White"
                       Canvas.Left="206"
                       Canvas.Top="85">

                                <Image x:Name="ImageUserAvatar"
                        Source="/Assets/Images/UserAvatar.png"
                        Width="60"
                        Height="60"
                        Stretch="Uniform"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                            </Border>
                        </Canvas>
                    </Grid>
                </Grid>

                <Border Grid.Row="1"
                BorderBrush="#2B2B2B"
                BorderThickness="0,2,0,0"
                Background="#F7F7F7">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ButtonMainMenu"
                    Grid.Column="0"
                    Content="Menu Principal  ⚔"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonMainMenu_Click"/>

                        <Button x:Name="ButtonProfile"
                    Grid.Column="1"
                    Content="Perfil  👤"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonProfile_Click"/>

                        <Button x:Name="ButtonHistory"
                    Grid.Column="2"
                    Content="Historial  ◴"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonHistory_Click"/>

                        <Button x:Name="ButtonScoreboard"
                    Grid.Column="3"
                    Content="Marcadores  🏆"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonScoreboard_Click"/>

                        <Button x:Name="ButtonSettings"
                    Grid.Column="4"
                    Content="Ajustes  ⚙"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonSettings_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
