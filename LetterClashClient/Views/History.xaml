<Page x:Class="LetterClashClient.Views.History"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="History"
      Loaded="Page_Loaded">

    <Grid Background="#F4F4F4">
        <Border Margin="20"
            BorderBrush="#2B2B2B"
            BorderThickness="2"
            Background="White">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
              Margin="30,25,30,20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="45"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58*"/>
                            <ColumnDefinition Width="42*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                    Width="620"
                    Height="90"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image x:Name="ImageStatistics"
                       Grid.Column="0"
                       Source="/Assets/Images/Stadistics.png"
                       Width="58"
                       Height="58"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                                <TextBlock Text="Estadísticas"
                           Grid.Column="1"
                           FontSize="19"
                           FontWeight="SemiBold"
                           Foreground="#111111"
                           VerticalAlignment="Center"/>

                                <Image x:Name="ImageUserAvatar"
                       Grid.Column="2"
                       Source="/Assets/Images/UserAvatar.png"
                       Width="58"
                       Height="58"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="3"
                            VerticalAlignment="Center">

                                    <TextBlock x:Name="TextBlockUsername"
                             Text="&quot;NOMBRE DE USUARIO&quot;"
                             FontSize="16"
                             FontWeight="SemiBold"
                             Foreground="#111111"
                             Margin="0,0,0,8"/>

                                    <TextBlock x:Name="TextBlockAge"
                             Text="&quot;EDAD&quot;"
                             FontSize="15"
                             FontWeight="SemiBold"
                             Foreground="#111111"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Image x:Name="ImageLogo"
                   Grid.Column="1"
                   Source="/Assets/Images/LogoLetterClash.jpeg"
                   Width="330"
                   Height="95"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
                    </Grid>

                    <DataGrid x:Name="DataGridHistory"
                    Grid.Row="1"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    IsReadOnly="True"
                    HeadersVisibility="Column"
                    GridLinesVisibility="All"
                    FontSize="16"
                    RowHeight="34"
                    ColumnHeaderHeight="35"
                    Margin="25,10,25,10"
                    SelectionChanged="DataGridHistory_SelectionChanged">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rival"
                                  Binding="{Binding Rival}"
                                  Width="*"/>

                            <DataGridTextColumn Header="Fecha"
                                  Binding="{Binding Fecha}"
                                  Width="*"/>

                            <DataGridTextColumn Header="Palabra"
                                  Binding="{Binding Palabra}"
                                  Width="*"/>

                            <DataGridTextColumn Header="Resultado"
                                  Binding="{Binding Resultado}"
                                  Width="*"/>

                            <DataGridTextColumn Header="Puntuación"
                                  Binding="{Binding Puntuacion}"
                                  Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2"
                  BorderBrush="#2B2B2B"
                  BorderThickness="1"
                  Background="#D9D9D9"
                  Margin="25,0,25,0">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="TextBlockTotalWins"
                         Grid.Column="0"
                         FontSize="14"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"/>

                            <TextBlock x:Name="TextBlockPercentWins"
                         Grid.Column="1"
                         FontSize="14"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"/>

                            <TextBlock x:Name="TextBlockTotalLosses"
                         Grid.Column="2"
                         FontSize="14"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"/>

                            <TextBlock x:Name="TextBlockPercentLosses"
                         Grid.Column="3"
                         FontSize="14"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"/>

                            <TextBlock x:Name="TextBlockTotalDisconnected"
                         Grid.Column="4"
                         FontSize="14"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"/>

                            <TextBlock x:Name="TextBlockPercentDisconnected"
                         Grid.Column="5"
                         FontSize="14"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                BorderBrush="#2B2B2B"
                BorderThickness="0,2,0,0"
                Background="#F7F7F7">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ButtonMainMenu"
                    Grid.Column="0"
                    Content="Menu Principal  ⚔"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonMainMenu_Click"/>

                        <Button x:Name="ButtonProfile"
                    Grid.Column="1"
                    Content="Perfil  👤"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonProfile_Click"/>

                        <Button x:Name="ButtonHistory"
                    Grid.Column="2"
                    Content="Historial  ◴"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonHistory_Click"/>

                        <Button x:Name="ButtonScoreboard"
                    Grid.Column="3"
                    Content="Marcadores  🏆"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonScoreboard_Click"/>

                        <Button x:Name="ButtonSettings"
                    Grid.Column="4"
                    Content="Ajustes  ⚙"
                    FontSize="15"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Click="ButtonSettings_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>