<Page x:Class="LetterClashClient.Views.GameHost"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GameHost"
      Loaded="Page_Loaded">

    <Grid Background="#F4F4F4">
        <Border Margin="20"
            BorderBrush="#2B2B2B"
            BorderThickness="2"
            Background="White">

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="95"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="165"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                  Width="280"
                  Height="70"
                  BorderBrush="#2B2B2B"
                  BorderThickness="1"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="85"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                         Text="⚔"
                         FontSize="44"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1"
                         Text="Partida"
                         FontSize="22"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                  Width="330"
                  Height="60"
                  BorderBrush="#2B2B2B"
                  BorderThickness="1"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                         Text="Vs"
                         FontSize="20"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>

                            <TextBlock x:Name="TextBlockOpponent"
                         Grid.Column="1"
                         Text="Usuario 1"
                         FontSize="18"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"/>

                            <Image x:Name="ImageOpponentAvatar"
                     Grid.Column="2"
                     Source="/Assets/Images/UserAvatar.png"
                     Width="58"
                     Height="58"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Button x:Name="ButtonAbandon"
                  Grid.Column="2"
                  Content="Abandonar  ⚑"
                  Width="145"
                  Height="38"
                  FontSize="14"
                  FontWeight="SemiBold"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Cursor="Hand"
                  Click="ButtonAbandon_Click"/>

                    <Image x:Name="ImageLogo"
                 Grid.Column="3"
                 Source="/Assets/Images/LogoLetterClash.jpeg"
                 Width="300"
                 Height="90"
                 Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="58*"/>
                        <ColumnDefinition Width="42*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="130"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="85"/>
                            <RowDefinition Height="150"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="1"
                       Text="Palabra seleccionada"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                        <TextBlock x:Name="TextBlockWord"
                       Grid.Row="2"
                       Text="SOFTWARE"
                       FontSize="38"
                       FontWeight="SemiBold"
                       Foreground="#1E1E2F"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                        <Border Grid.Row="3"
                    Width="520"
                    Height="120"
                    BorderBrush="#2B2B2B"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                           Text="Letra seleccionada por el adivinador"
                           FontSize="17"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                                <TextBlock x:Name="TextBlockSelectedLetter"
                           Grid.Row="1"
                           Text="A"
                           FontSize="38"
                           FontWeight="SemiBold"
                           Foreground="#1E1E2F"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="230"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="220"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Canvas x:Name="CanvasHangmanGame"
                    Grid.Row="0"
                    Width="340"
                    Height="220"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                            <Image x:Name="ImageHangman"
                     Source="/Assets/Images/Hangedman5.jpg"
                     Width="280"
                     Height="210"
                     Stretch="Uniform"
                     Canvas.Left="25"
                     Canvas.Top="5"/>

                            <Border x:Name="BorderUserAvatar"
                      Width="66"
                      Height="66"
                      CornerRadius="33"
                      BorderBrush="#2B2B2B"
                      BorderThickness="2"
                      Background="White"
                      Canvas.Left="192"
                      Canvas.Top="57">

                                <Image x:Name="ImageUserAvatar"
                       Source="/Assets/Images/UserAvatar.png"
                       Width="52"
                       Height="52"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                            </Border>
                        </Canvas>

                        <Grid Grid.Row="1"
                  Width="360"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="65"/>
                            </Grid.ColumnDefinitions>

                            <ProgressBar x:Name="ProgressBarAttempts"
                           Grid.Column="0"
                           Height="24"
                           Minimum="0"
                           Maximum="5"
                           Value="0"/>

                            <TextBlock x:Name="TextBlockAttempts"
                         Grid.Column="1"
                         Text="0/5"
                         FontSize="17"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="GridChat"
                  Grid.Row="2"
                  Width="410"
                  Height="210"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top"
                  Margin="0,5,0,0">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="35"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                      BorderBrush="#2B2B2B"
                      BorderThickness="1">

                                <TextBlock x:Name="TextBlockChatTitle"
                           Text="Chat con Usuario 1"
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBox x:Name="TextBoxChatMessages"
                       Grid.Row="1"
                       Text="Usuario 1: Hola&#x0a;Usuario 1: Estoy listo"
                       FontSize="14"
                       IsReadOnly="True"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto"
                       BorderBrush="#2B2B2B"
                       BorderThickness="1"/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="75"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="TextBoxChatInput"
                         Grid.Column="0"
                         FontSize="14"
                         Padding="6,4"
                         BorderBrush="#2B2B2B"
                         BorderThickness="1"/>

                                <Button x:Name="ButtonSendMessage"
                        Grid.Column="1"
                        Content="Enviar"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="ButtonSendMessage_Click"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>