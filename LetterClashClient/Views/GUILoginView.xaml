<Page x:Class="LetterClashClient.Views.GUILoginView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      Title="GUILoginView"
      Loaded="Page_Loaded">

    <Grid Background="#F4F4F4">
        <Border Margin="20"
            BorderBrush="#2B2B2B"
            BorderThickness="2"
            Background="White">

            <Grid Margin="35">
                <Grid.RowDefinitions>
                    <RowDefinition Height="110"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="60"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                   Text="I N G R E S O"
                   FontSize="42"
                   FontWeight="SemiBold"
                   Foreground="#1E1E2F"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Margin="45,0,0,0"/>

                <Rectangle Grid.Row="0"
                   Height="3"
                   Width="430"
                   Fill="#1E1E2F"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Bottom"
                   Margin="35,0,0,10"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64*"/>
                        <ColumnDefinition Width="2"/>
                        <ColumnDefinition Width="36*"/>
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="GridLoginForm"
                 Grid.Column="0"
                 Width="540"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="35,25,0,0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="50"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                        Text="Nombre de Usuario"
                        FontSize="15"
                        Foreground="#222222"/>

                        <Grid Grid.Row="1">
                            <TextBox x:Name="TextBoxUsername"
                        Height="35"
                        FontSize="15"
                        Padding="8,4"
                        TextChanged="TextBoxUsername_TextChanged"/>

                            <TextBlock x:Name="TextBlockUsernamePlaceholder"
                          Text="Usuario"
                          FontSize="15"
                          Foreground="#999999"
                          Margin="10,0,0,0"
                          VerticalAlignment="Center"
                          IsHitTestVisible="False"/>
                        </Grid>

                        <TextBlock x:Name="TextBlockUsernameError"
                        Grid.Row="2"
                        Text="Usuario No Valido / No encontrado"
                        FontSize="14"
                        Foreground="Red"
                        VerticalAlignment="Center"
                        Visibility="Hidden"/>

                        <TextBlock Grid.Row="3"
                        Text="O usa"
                        FontSize="16"
                        Foreground="#222222"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="4"
                        Text="Correo"
                        FontSize="15"
                        Foreground="#222222"/>

                        <Grid Grid.Row="5">
                            <TextBox x:Name="TextBoxEmail"
                        Height="35"
                        FontSize="15"
                        Padding="8,4"
                        TextChanged="TextBoxEmail_TextChanged"/>

                            <TextBlock x:Name="TextBlockEmailPlaceholder"
                          Text="Correo Electronico"
                          FontSize="15"
                          Foreground="#999999"
                          Margin="10,0,0,0"
                          VerticalAlignment="Center"
                          IsHitTestVisible="False"/>
                        </Grid>

                        <TextBlock x:Name="TextBlockEmailError"
                        Grid.Row="6"
                        Text="Este Usuario no existe"
                        FontSize="14"
                        Foreground="Red"
                        VerticalAlignment="Center"
                        Visibility="Hidden"/>

                        <TextBlock Grid.Row="7"
                        Text="Contraseña"
                        FontSize="15"
                        Foreground="#222222"/>

                        <Grid Grid.Row="8">
                            <PasswordBox x:Name="PasswordBoxPassword"
                            Height="35"
                            FontSize="15"
                            Padding="8,4"
                            PasswordChanged="PasswordBoxPassword_PasswordChanged"/>

                            <TextBlock x:Name="TextBlockPasswordPlaceholder"
                          Text="Contraseña"
                          FontSize="15"
                          Foreground="#999999"
                          Margin="10,0,0,0"
                          VerticalAlignment="Center"
                          IsHitTestVisible="False"/>
                        </Grid>

                        <TextBlock x:Name="TextBlockPasswordError"
                        Grid.Row="9"
                        Text="Coloque su contraseña"
                        FontSize="14"
                        Foreground="Red"
                        VerticalAlignment="Center"
                        Visibility="Hidden"/>

                        <Button x:Name="ButtonLogin"
                     Grid.Row="10"
                     Content="Iniciar Sesion"
                     Width="230"
                     Height="38"
                     FontSize="15"
                     FontWeight="SemiBold"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Cursor="Hand"
                     Click="ButtonLogin_Click"/>
                    </Grid>

                    <Border Grid.Column="1"
                   Background="#2B2B2B"
                   Width="2"
                   VerticalAlignment="Stretch"/>

                    <Grid Grid.Column="2">
                        <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,15,0,0">

                            <Image x:Name="ImageLogo"
                      Source="/Assets/Images/LogoLetterClash.jpeg"
                      Width="360"
                      Height="140"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,45"/>

                            <TextBlock Text="O eres nuevo?? ☹"
                          FontSize="17"
                          Foreground="#222222"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,15"/>

                            <Button x:Name="ButtonCreateAccount"
                       Content="Crear una Cuenta"
                       Width="210"
                       Height="38"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Cursor="Hand"
                       Click="ButtonCreateAccount_Click"/>

                            <TextBlock Text="N E W"
                          FontSize="28"
                          Foreground="#1E1E2F"
                          HorizontalAlignment="Center"
                          Margin="0,70,0,0"/>

                            <Rectangle Height="2"
                          Fill="#1E1E2F"
                          Width="130"
                          Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <Button x:Name="ButtonBackHome"
                 Grid.Row="2"
                 Content="Pagina Inicial  ↩"
                 Width="190"
                 Height="38"
                 FontSize="15"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Cursor="Hand"
                 Click="ButtonBackHome_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
