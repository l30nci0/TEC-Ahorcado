<Window x:Class="LetterClashClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LetterClash"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" 
                      ResizeBorderThickness="6" 
                      GlassFrameThickness="0" 
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid Background="#09090B">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" x:Name="GridTitleBar" Background="#121214" MouseLeftButtonDown="GridTitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title Text -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                <TextBlock Text="LETTER CLASH" 
                           FontFamily="{StaticResource GeistPixelSquare}" 
                           FontSize="12" 
                           FontWeight="Bold"
                           Foreground="#A1A1AA" 
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Window Controls (macOS style) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True">
                <!-- Close Button (Red) -->
                <Button x:Name="ButtonClose" 
                        Width="20" 
                        Height="36" 
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="ButtonClose_Click"
                        ToolTip="Cerrar">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" SnapsToDevicePixels="True">
                                <Border x:Name="circle" 
                                        Width="12" 
                                        Height="12" 
                                        CornerRadius="6" 
                                        Background="#FF5F56" 
                                        BorderBrush="#E0443E" 
                                        BorderThickness="0.5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="circle" Property="Background" Value="#FF4A40"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Minimize Button (Yellow) -->
                <Button x:Name="ButtonMinimize" 
                        Width="20" 
                        Height="36" 
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="ButtonMinimize_Click"
                        ToolTip="Minimizar">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" SnapsToDevicePixels="True">
                                <Border x:Name="circle" 
                                        Width="12" 
                                        Height="12" 
                                        CornerRadius="6" 
                                        Background="#FFBD2E" 
                                        BorderBrush="#DEA123" 
                                        BorderThickness="0.5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="circle" Property="Background" Value="#FFAB15"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Maximize Button (Green) -->
                <Button x:Name="ButtonMaximize" 
                        Width="20" 
                        Height="36" 
                        Margin="0,0,16,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="ButtonMaximize_Click"
                        ToolTip="Maximizar">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" SnapsToDevicePixels="True">
                                <Border x:Name="circle" 
                                        Width="12" 
                                        Height="12" 
                                        CornerRadius="6" 
                                        Background="#27C93F" 
                                        BorderBrush="#1A9C2B" 
                                        BorderThickness="0.5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="circle" Property="Background" Value="#1FD338"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Divider line -->
        <Border Grid.Row="0" BorderBrush="#27272A" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

        <!-- Main Content Frame -->
        <Frame x:Name="MainFrame" 
               Grid.Row="1" 
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
